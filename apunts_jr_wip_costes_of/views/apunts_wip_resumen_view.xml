<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="apunts_wip_resumen_form" model="ir.ui.view">
        <field name="name">apunts.wip.resumen.form</field>
        <field name="model">apunts.wip.resumen</field>
        <field name="arch" type="xml">
            <form string="Resumen WIP" create="0" delete="0">
                <sheet>
                    <!-- SELECTOR DE MODO + FILTRO FECHAS -->
                    <div class="d-flex flex-wrap align-items-center gap-3 mb-3 p-3 bg-light rounded">
                        <div class="d-flex align-items-center gap-2">
                            <span class="fw-semibold text-muted">Vista:</span>
                            <field name="modo" widget="radio" nolabel="1"/>
                        </div>
                        <div class="d-flex align-items-center gap-2" invisible="modo != 'historico'">
                            <span class="fw-semibold text-muted">Cerradas entre</span>
                            <field name="fecha_desde" nolabel="1" placeholder="Desde..."/>
                            <span class="text-muted">–</span>
                            <field name="fecha_hasta" nolabel="1" placeholder="Hasta..."/>
                        </div>
                    </div>

                    <div class="oe_title mb-3">
                        <h1 invisible="modo != 'en_curso'">Resumen Trabajo en Curso</h1>
                        <h1 invisible="modo != 'historico'">Historial de Producción</h1>
                        <p class="text-muted" invisible="modo != 'en_curso'">
                            Foto global ahora mismo de todas las OFs en curso (WIP).
                            Para detalle por OF, filtros y agrupaciones, abre la lista detallada.
                        </p>
                        <p class="text-muted" invisible="modo != 'historico'">
                            Totales de OFs terminadas filtradas por fecha de cierre.
                            Selecciona un rango de fechas para ver el resumen histórico.
                        </p>
                    </div>

                    <div class="d-flex justify-content-center gap-2 mb-4">
                        <button name="action_open_lista_wip" type="object"
                                string="EN CURSO — abrir lista detallada"
                                class="btn btn-lg btn-primary"
                                invisible="modo != 'en_curso'"/>
                        <button name="action_forzar_recompute" type="object"
                                string="↻ Forzar recompute"
                                class="btn btn-lg btn-secondary"
                                invisible="modo != 'en_curso'"
                                help="Recalcula todos los campos del WIP. Útil si acabas de recibir una PO y los datos no se han refrescado todavía."/>
                        <button name="action_open_lista_historico" type="object"
                                string="HISTORIAL — abrir lista terminadas"
                                class="btn btn-lg btn-info"
                                invisible="modo != 'historico'"/>
                    </div>

                    <field name="n_ofs_bom_incompleta" invisible="1"/>

                    <div class="row row-cols-1 row-cols-sm-2 row-cols-xl-5 g-3">
                        <div class="col">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1" invisible="modo != 'en_curso'">Órdenes en curso</div>
                                    <div class="text-uppercase fw-semibold small text-muted mb-1" invisible="modo != 'historico'">Órdenes terminadas</div>
                                    <div class="display-5 fw-bold text-primary">
                                        <field name="n_ofs_wip" nolabel="1" readonly="1"/>
                                    </div>
                                    <div class="small text-muted mt-1" invisible="modo != 'en_curso'">
                                        Órdenes de fabricación con material ya consumido
                                        o con material recibido del proveedor (aunque
                                        la orden aún no haya empezado a trabajarse).
                                    </div>
                                    <div class="small text-muted mt-1" invisible="modo != 'historico'">
                                        Órdenes de fabricación terminadas en el período seleccionado.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Venta total</div>
                                    <div class="display-6 fw-bold text-success">
                                        <field name="total_venta" nolabel="1" readonly="1" widget="monetary"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Importe del pedido de venta confirmado vinculado
                                        a estas órdenes (sólo pedidos confirmados).
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1" invisible="modo != 'en_curso'">En curso (real)</div>
                                    <div class="text-uppercase fw-semibold small text-muted mb-1" invisible="modo != 'historico'">Coste real total</div>
                                    <div class="display-6 fw-bold text-warning">
                                        <field name="total_cost_real" nolabel="1" readonly="1" widget="monetary"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Material recibido + mano de obra fichada + máquina ya invertida.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Coste teórico total</div>
                                    <div class="display-6 fw-bold text-primary">
                                        <field name="total_cost_planned" nolabel="1" readonly="1" widget="monetary"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Material teórico + mano de obra teórica + máquina teórica,
                                        según lista de materiales y operaciones.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Margen estimado</div>
                                    <div class="display-6 fw-bold text-success">
                                        <field name="margen_estimado" nolabel="1" readonly="1" widget="monetary"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Venta total menos coste teórico total.
                                        Es el margen esperado si todo va según lo previsto.
                                    </div>
                                    <div class="small fw-bold mt-2">
                                        Factor: <field name="factor_global" nolabel="1" readonly="1" widget="float" digits="[16,2]" class="oe_inline"/>×
                                    </div>
                                    <div class="small fw-bold">
                                        Avance: <field name="grado_avance" nolabel="1" readonly="1" widget="float" digits="[16,1]" class="oe_inline"/>%
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <h3 class="mt-4">Desglose por concepto</h3>
                    <table class="table table-bordered align-middle mt-2">
                        <thead>
                            <tr>
                                <th class="text-start">Concepto</th>
                                <th class="text-end">Teórico</th>
                                <th class="text-end">Real</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-start">
                                    <div class="fw-bold">MP (Materia Prima)</div>
                                    <div class="small text-muted">
                                        Teórico: lista de materiales × cantidad de la orden × precio.
                                        Real: lo recibido del proveedor (línea de compra con campo Fabricación)
                                        más lo ya consumido en taller.
                                    </div>
                                </td>
                                <td class="text-end h4 mb-0">
                                    <field name="total_mat_planned" nolabel="1" readonly="1" widget="monetary"/>
                                </td>
                                <td class="text-end h4 mb-0">
                                    <field name="total_mat_real" nolabel="1" readonly="1" widget="monetary"/>
                                </td>
                            </tr>
                            <field name="total_mat_planned_ajustado" invisible="1"/>
                            <tr invisible="modo != 'en_curso'">
                                <td class="text-start">
                                    <div class="fw-bold ps-4">↳ MP pendiente de recibir</div>
                                    <div class="small text-muted ps-4">
                                        Importe de las líneas de compra vinculadas a estas órdenes,
                                        en estado confirmado, que aún no han llegado del proveedor.
                                    </div>
                                </td>
                                <td class="text-end h4 mb-0 text-muted">—</td>
                                <td class="text-end h4 mb-0 text-warning">
                                    <field name="total_mp_pendiente_recibir" nolabel="1" readonly="1" widget="monetary"/>
                                </td>
                            </tr>
                            <tr class="table-secondary">
                                <td class="text-start">
                                    <div class="fw-bold">Tiempo de fabricación</div>
                                    <div class="small text-muted">
                                        Teórico: minutos previstos en las operaciones del producto.
                                        Real: minutos que los operarios han fichado en las órdenes de trabajo.
                                    </div>
                                </td>
                                <td class="text-end">
                                    <div class="h4 mb-0">
                                        <field name="total_min_planned" nolabel="1" readonly="1" widget="float" digits="[16,0]"/> min
                                    </div>
                                    <div class="small text-muted">
                                        ≈ <field name="total_horas_planned" nolabel="1" readonly="1" widget="float" digits="[16,1]"/> h
                                        · <field name="total_jornadas_planned" nolabel="1" readonly="1" widget="float" digits="[16,1]"/> días laborales (8h)
                                    </div>
                                </td>
                                <td class="text-end">
                                    <div class="h4 mb-0">
                                        <field name="total_min_real" nolabel="1" readonly="1" widget="float" digits="[16,0]"/> min
                                    </div>
                                    <div class="small text-muted">
                                        ≈ <field name="total_horas_real" nolabel="1" readonly="1" widget="float" digits="[16,1]"/> h
                                        · <field name="total_jornadas_real" nolabel="1" readonly="1" widget="float" digits="[16,1]"/> días laborales (8h)
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-start">
                                    <div class="fw-bold ps-4">↳ Coste operario</div>
                                    <div class="small text-muted ps-4">
                                        Teórico: minutos previstos × tarifa hora del empleado
                                        (centro de trabajo si no hay empleado asignado).
                                        Real: minutos fichados × misma tarifa.
                                    </div>
                                </td>
                                <td class="text-end h4 mb-0">
                                    <field name="total_mo_planned" nolabel="1" readonly="1" widget="monetary"/>
                                </td>
                                <td class="text-end h4 mb-0">
                                    <field name="total_mo_real" nolabel="1" readonly="1" widget="monetary"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-start">
                                    <div class="fw-bold ps-4">↳ Coste máquina</div>
                                    <div class="small text-muted ps-4">
                                        Teórico: minutos previstos × coste por hora del centro de trabajo.
                                        Real: minutos fichados × coste por hora del centro.
                                    </div>
                                </td>
                                <td class="text-end h4 mb-0">
                                    <field name="total_machine_planned" nolabel="1" readonly="1" widget="monetary"/>
                                </td>
                                <td class="text-end h4 mb-0">
                                    <field name="total_machine_real" nolabel="1" readonly="1" widget="monetary"/>
                                </td>
                            </tr>
                            <tr class="table-active">
                                <td class="text-start fw-bold">TOTAL</td>
                                <td class="text-end h4 mb-0 fw-bold">
                                    <field name="total_cost_planned" nolabel="1" readonly="1" widget="monetary"/>
                                </td>
                                <td class="text-end h4 mb-0 fw-bold">
                                    <field name="total_cost_real" nolabel="1" readonly="1" widget="monetary"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <field name="currency_id" invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="apunts_action_wip_resumen_srv" model="ir.actions.server">
        <field name="name">Resumen WIP</field>
        <field name="model_id" ref="model_apunts_wip_resumen"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_resumen()</field>
    </record>

</odoo>
