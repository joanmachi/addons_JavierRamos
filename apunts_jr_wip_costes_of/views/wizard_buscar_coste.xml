<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="apunts_view_buscar_coste_of_form" model="ir.ui.view">
        <field name="name">apunts.buscar.coste.of.form</field>
        <field name="model">apunts.buscar.coste.of</field>
        <field name="arch" type="xml">
            <form string="Buscar Coste OF">
                <sheet>
                    <div class="oe_title">
                        <h2>Buscar Coste de OF</h2>
                        <p>Selecciona la orden de fabricación para abrir su pantalla de coste consolidado en tiempo real.</p>
                    </div>
                    <group>
                        <field name="production_id" options="{'no_create': True, 'no_open': True}"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Ver Coste OF" name="action_open_coste" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="apunts_action_buscar_coste_of" model="ir.actions.act_window">
        <field name="name">Buscar Coste OF</field>
        <field name="res_model">apunts.buscar.coste.of</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="apunts_view_buscar_coste_of_form"/>
        <field name="target">new</field>
    </record>

</odoo>
