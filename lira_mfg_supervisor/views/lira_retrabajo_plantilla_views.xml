<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ── Form ── -->
  <record id="view_lira_retrabajo_plantilla_form" model="ir.ui.view">
    <field name="name">lira.retrabajo.plantilla.form</field>
    <field name="model">lira.retrabajo.plantilla</field>
    <field name="arch" type="xml">
      <form string="Plantilla de retrabajo">
        <sheet>
          <div class="oe_title">
            <h1><field name="name" placeholder="Nombre de la plantilla"/></h1>
          </div>
          <notebook>
            <page string="Fases" name="fases">
              <field name="linea_ids">
                <list editable="bottom">
                  <field name="secuencia" widget="handle"/>
                  <field name="nombre"/>
                  <field name="workcenter_id"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <!-- ── List ── -->
  <record id="view_lira_retrabajo_plantilla_list" model="ir.ui.view">
    <field name="name">lira.retrabajo.plantilla.list</field>
    <field name="model">lira.retrabajo.plantilla</field>
    <field name="arch" type="xml">
      <list string="Plantillas de retrabajo">
        <field name="name"/>
        <field name="linea_ids" widget="many2many_tags"
               options="{'color_field': 'secuencia'}"
               string="Fases"/>
      </list>
    </field>
  </record>

  <!-- ── Action ── -->
  <record id="action_lira_retrabajo_plantilla" model="ir.actions.act_window">
    <field name="name">Plantillas de retrabajo</field>
    <field name="res_model">lira.retrabajo.plantilla</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>
