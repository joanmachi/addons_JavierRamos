<?xml version="1.0" encoding="utf-8"?>
<odoo>


  
   

    <record id="view_pedido_form" model="ir.ui.view">
        <field name="name">javier_ramos_pedidos.pedido.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_stock.view_order_form_inherit_sale_stock" />
        <field name="arch" type="xml">

            <xpath expr="//sheet/notebook/page[1]/field[@name='order_line']/list/field[@name='name']" position="after">
              <field name="pos_palet"/>
            </xpath>
            <xpath expr="//button[@name='action_confirm']" position="after">
                <field name="create_uid" invisible="1"/>
                <button name="action_generate_product_reference" data-hotkey="q" string="Generar referencias productos" type="object" context="{'validate_analytic': True}" invisible="not create_uid"/>
            </xpath>
            <xpath expr="//label[@for='date_order']" position="replace">
                
            </xpath>
            <xpath expr="//label[@for='commitment_date']" position="replace">
                
            </xpath>
            <xpath expr="//field[@name='validity_date']" position="replace">
                <group>
                    <field name="validity_date" invisible="state == 'sale'" readonly="state in ['cancel', 'sale']"/>

                </group>
            </xpath>
            <xpath expr="//field[@name='date_order']" position="replace">
                <group>
                    <field name="date_order"  groups="base.group_no_one" invisible="state in ['sale', 'cancel']" readonly="state in ['cancel', 'sale']"/>

                </group>
            </xpath>
          
            <xpath expr="//span[@invisible='effective_date and commitment_date']" position="replace">
                
            </xpath>
          
            <xpath expr="//field[@name='payment_term_id']" position="replace">
                <group style="width:100%">
                    
                    <field name="payment_term_id"/>
                        <label for="commitment_date"/>
                        <div class="o_row" >
                            <field name="commitment_date" />
                        <button name="action_update_fecha_entrega" type="object" string="Actualizar fecha" class="btn-link mb-1 px-0" icon="fa-refresh"/>
                       </div>
                    <span class="text-muted" invisible="effective_date and commitment_date">Expected: <field name="expected_date" class="oe_inline"/></span>
        

                </group>
            </xpath>
        </field>
    </record>




    
</odoo>