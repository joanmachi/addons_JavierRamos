<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ── LÍNEAS DE COMPRA — Lista ──────────────────────────────────────── -->
  <record id="view_jr_purchase_line_desglose_list" model="ir.ui.view">
    <field name="name">jr.purchase.order.line.desglose.list</field>
    <field name="model">purchase.order.line</field>
    <field name="arch" type="xml">
      <list string="Desglose líneas de compra" create="0" delete="0" edit="0"
            decoration-muted="jr_qty_to_receive == 0">

        <field name="order_id"        string="Pedido"/>
        <field name="jr_partner_id"   string="Proveedor"/>
        <field name="product_id"         string="Producto"/>
        <field name="name"               string="Descripción"   optional="hide"/>

        <field name="product_qty"        string="Pedido"        sum="Total pedido"/>
        <field name="qty_received"       string="Recibido"      sum="Total recibido"/>
        <field name="jr_qty_to_receive"  string="Pdte. recibir" sum="Total pendiente"
               decoration-danger="jr_qty_to_receive > 0"
               decoration-muted="jr_qty_to_receive == 0"/>

        <field name="date_planned"       string="Fecha prevista"/>

        <field name="price_unit"         string="Precio"        optional="show"/>
        <field name="price_subtotal"     string="Subtotal"      sum="Total"  optional="show"/>

      </list>
    </field>
  </record>

  <!-- ── LÍNEAS DE COMPRA — Búsqueda ──────────────────────────────────── -->
  <record id="view_jr_purchase_line_desglose_search" model="ir.ui.view">
    <field name="name">jr.purchase.order.line.desglose.search</field>
    <field name="model">purchase.order.line</field>
    <field name="arch" type="xml">
      <search string="Buscar líneas de compra">

        <field name="order_id"    string="Pedido"/>
        <field name="product_id"  string="Producto"/>
        <field name="name"        string="Descripción"/>

        <separator/>
        <filter name="filter_pending"
                string="Pendiente de recibir"
                domain="[('jr_qty_to_receive', '&gt;', 0), ('state', 'in', ['purchase', 'done'])]"/>
        <filter name="filter_overdue"
                string="Plazo vencido"
                domain="[
                  ('jr_qty_to_receive', '&gt;', 0),
                  ('state', 'in', ['purchase', 'done']),
                  ('date_planned', '&lt;', context_today().strftime('%Y-%m-%d'))
                ]"/>

        <separator/>
        <filter name="filter_7days"
                string="Previstos próximos 7 días"
                domain="[
                  ('date_planned', '&gt;=', context_today().strftime('%Y-%m-%d')),
                  ('date_planned', '&lt;=', (context_today() + datetime.timedelta(days=7)).strftime('%Y-%m-%d'))
                ]"/>
        <filter name="filter_31days"
                string="Previstos próximos 31 días"
                domain="[
                  ('date_planned', '&gt;=', context_today().strftime('%Y-%m-%d')),
                  ('date_planned', '&lt;=', (context_today() + datetime.timedelta(days=31)).strftime('%Y-%m-%d'))
                ]"/>

        <group expand="1" string="Agrupar por">
          <filter name="group_product"  string="Producto"
                  context="{'group_by': 'product_id'}"/>
          <filter name="group_order"    string="Pedido"
                  context="{'group_by': 'order_id'}"/>
          <filter name="group_partner"  string="Proveedor"
                  context="{'group_by': 'jr_partner_id'}"/>
          <filter name="group_date"     string="Fecha prevista"
                  context="{'group_by': 'date_planned:week'}"/>
        </group>

      </search>
    </field>
  </record>

  <!-- ── LÍNEAS DE COMPRA — Acción ────────────────────────────────────── -->
  <record id="action_jr_purchase_line_desglose" model="ir.actions.act_window">
    <field name="name">Desglose líneas de compra</field>
    <field name="res_model">purchase.order.line</field>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_jr_purchase_line_desglose_list"/>
    <field name="search_view_id" ref="view_jr_purchase_line_desglose_search"/>
    <field name="domain">[('state', 'in', ['purchase', 'done']), ('product_qty', '&gt;', 0)]</field>
    <field name="context">{'search_default_filter_pending': 1}</field>
  </record>


</odoo>
