<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="sh_stock_picking_form_view_custom" model="ir.ui.view">
        <field name="name">sh.stock.picking.form.view.custom</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form" />
        <field name="arch" type="xml">
          

            <xpath expr="//field[@name='move_ids_without_package']/list/field[@name='product_uom']" position="before">
                <field name="pos_palet"  />
            </xpath>
         
        </field>
    </record>
    <record id="stock_picking_type_kanban_inherit" model="ir.ui.view">
        <field name="name">stock.picking.type.kanban.inherit</field>
        <field name="model">stock.picking.type</field>
        <field name="inherit_id" ref="stock.stock_picking_type_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='kanban_dashboard_graph']" position="attributes">
                <attribute name="measure">total_value</attribute>
                <attribute name="options">{'measure': 'total_value'}</attribute>
            </xpath>
        </field>
    </record>

</odoo>