<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!--
    Ambos records heredan de product_template_only_form_view (igual que el módulo stock).
    Record 1 (priority 16): añade nuestros 3 botones ANTES de Pronosticado.
    Record 2 (priority 17): oculta Pronosticado original y lo añade al final.
    El módulo stock tiene priority=15 → se aplica primero, luego nosotros.
  -->

  <!-- Añadir Saliente / En fabricación / Compras pdte. antes de Pronosticado -->
  <record id="view_jr_product_template_stock_buttons" model="ir.ui.view">
    <field name="name">jr.product.template.stock.buttons</field>
    <field name="model">product.template</field>
    <field name="inherit_id" ref="product.product_template_only_form_view"/>
    <field name="priority" eval="16"/>
    <field name="arch" type="xml">
      <xpath expr="//button[@name='action_product_tmpl_forecast_report']" position="before">
        <button type="object" name="action_jr_ver_saliente"
                class="oe_stat_button" icon="fa-arrow-circle-up">
          <div class="o_field_widget o_stat_info">
            <span class="o_stat_value d-flex gap-1">
              <field name="jr_qty_pendiente_entrega" nolabel="1" class="oe_inline"/>
            </span>
            <span class="o_stat_text">Saliente</span>
          </div>
        </button>
        <button type="object" name="action_jr_ver_fabricacion"
                class="oe_stat_button" icon="fa-cogs">
          <div class="o_field_widget o_stat_info">
            <span class="o_stat_value d-flex gap-1">
              <field name="jr_qty_pendiente_of" nolabel="1" class="oe_inline"/>
            </span>
            <span class="o_stat_text">En fabricación</span>
          </div>
        </button>
        <button type="object" name="action_jr_ver_compras"
                class="oe_stat_button" icon="fa-shopping-cart">
          <div class="o_field_widget o_stat_info">
            <span class="o_stat_value d-flex gap-1">
              <field name="jr_qty_pendiente_compra" nolabel="1" class="oe_inline"/>
            </span>
            <span class="o_stat_text">Compras pdte.</span>
          </div>
        </button>
      </xpath>
    </field>
  </record>

  <!-- Ocultar Pronosticado original y añadirlo al final -->
  <record id="view_jr_product_template_forecast_last" model="ir.ui.view">
    <field name="name">jr.product.template.forecast.last</field>
    <field name="model">product.template</field>
    <field name="inherit_id" ref="product.product_template_only_form_view"/>
    <field name="priority" eval="17"/>
    <field name="arch" type="xml">
      <xpath expr="//button[@name='action_product_tmpl_forecast_report']" position="attributes">
        <attribute name="invisible">1</attribute>
      </xpath>
      <xpath expr="//div[@name='button_box']" position="inside">
        <button type="object"
                name="action_product_tmpl_forecast_report"
                invisible="not show_forecasted_qty_status_button"
                context="{'default_product_tmpl_id': id}"
                class="oe_stat_button" icon="fa-area-chart">
          <div class="o_field_widget o_stat_info">
            <span class="o_stat_value d-flex gap-1">
              <field name="virtual_available" nolabel="1" class="oe_inline"/>
              <field name="uom_name" class="oe_inline" groups="uom.group_uom"/>
            </span>
            <span class="o_stat_text">Pronosticado</span>
          </div>
        </button>
      </xpath>
    </field>
  </record>

</odoo>
