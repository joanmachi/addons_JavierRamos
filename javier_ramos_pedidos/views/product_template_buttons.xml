<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Añadir los 3 botones al button_box (base product form — funciona siempre) -->
  <record id="view_jr_product_template_stock_buttons" model="ir.ui.view">
    <field name="name">jr.product.template.stock.buttons</field>
    <field name="model">product.template</field>
    <field name="inherit_id" ref="product.product_template_form_view"/>
    <field name="arch" type="xml">
      <xpath expr="//div[@name='button_box']" position="inside">
        <button type="object" name="action_jr_ver_saliente"
                class="oe_stat_button" icon="fa-arrow-circle-up">
          <field name="jr_qty_pendiente_entrega" widget="statinfo" string="Saliente"/>
        </button>
        <button type="object" name="action_jr_ver_fabricacion"
                class="oe_stat_button" icon="fa-cogs">
          <field name="jr_qty_pendiente_of" widget="statinfo" string="En fabricación"/>
        </button>
        <button type="object" name="action_jr_ver_compras"
                class="oe_stat_button" icon="fa-shopping-cart">
          <field name="jr_qty_pendiente_compra" widget="statinfo" string="Compras pdte."/>
        </button>
      </xpath>
    </field>
  </record>

  <!-- Mover Pronosticado al final (hereda de la vista stock que lo define) -->
  <record id="view_jr_product_template_forecast_last" model="ir.ui.view">
    <field name="name">jr.product.template.forecast.last</field>
    <field name="model">product.template</field>
    <field name="inherit_id" ref="stock.product_template_form_view_procurement_button"/>
    <field name="arch" type="xml">
      <!-- Ocultar el Pronosticado original -->
      <xpath expr="//button[@name='action_product_tmpl_forecast_report']" position="attributes">
        <attribute name="invisible">1</attribute>
      </xpath>
      <!-- Añadir copia de Pronosticado al final del button_box -->
      <xpath expr="//div[@name='button_box']" position="inside">
        <button type="object"
                name="action_product_tmpl_forecast_report"
                invisible="not show_forecasted_qty_status_button"
                context="{'default_product_tmpl_id': id}"
                class="oe_stat_button" icon="fa-area-chart">
          <div class="o_field_widget o_stat_info">
            <span class="o_stat_value d-flex gap-1">
              <field name="virtual_available" nolabel="1" class="oe_inline"/>
              <field name="uom_name" class="oe_inline" groups="uom.group_uom"/>
            </span>
            <span class="o_stat_text">Pronosticado</span>
          </div>
        </button>
      </xpath>
    </field>
  </record>

</odoo>
