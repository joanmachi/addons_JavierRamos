<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_jr_product_template_stock_buttons" model="ir.ui.view">
    <field name="name">jr.product.template.stock.buttons</field>
    <field name="model">product.template</field>
    <field name="inherit_id" ref="product.product_template_form_view"/>
    <field name="arch" type="xml">
      <xpath expr="//div[@name='button_box']" position="inside">

        <!-- Saliente: qty pendiente de entregar en pedidos de venta -->
        <button type="object" name="action_jr_ver_saliente"
                class="oe_stat_button" icon="fa-arrow-circle-up"
                invisible="jr_qty_pendiente_entrega == 0">
          <field name="jr_qty_pendiente_entrega" widget="statinfo"
                 string="Saliente"/>
        </button>

        <!-- En fabricación: qty en OFs confirmadas/en curso -->
        <button type="object" name="action_jr_ver_fabricacion"
                class="oe_stat_button" icon="fa-cogs"
                invisible="jr_qty_pendiente_of == 0">
          <field name="jr_qty_pendiente_of" widget="statinfo"
                 string="En fabricación"/>
        </button>

        <!-- Compras pendientes: qty por recibir en órdenes de compra -->
        <button type="object" name="action_jr_ver_compras"
                class="oe_stat_button" icon="fa-shopping-cart"
                invisible="jr_qty_pendiente_compra == 0">
          <field name="jr_qty_pendiente_compra" widget="statinfo"
                 string="Compras pdte."/>
        </button>

      </xpath>
    </field>
  </record>

</odoo>
