<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_account_invoice_custom" inherit_id="account.report_invoice_document">
        <xpath expr="//div[@id='informations']" position="replace">
            <div id="informations" class="row mb-4">
                <div class="col" t-if="o.invoice_date" name="invoice_date">
                    <t t-if="o.move_type == 'out_invoice'"><strong>Fecha de factura</strong></t>
                    <t t-elif="o.move_type == 'out_refund'"><strong>Fecha de la factura rectificativa</strong></t>
                    <t t-elif="o.move_type == 'out_receipt'"><strong>Fecha del recibo</strong></t>
                    <t t-else=""><strong>Fecha</strong></t>
                    <div t-field="o.invoice_date">2023-09-12</div>
                </div>
                <div class="col" t-if="o.invoice_date_due and o.move_type == 'out_invoice' and o.state == 'posted'" name="due_date">
                    <strong>Fecha de vencimiento</strong>
                    <div t-field="o.invoice_date_due">2023-10-31</div>
                </div>
                <div class="col" t-if="o.delivery_date" name="delivery_date">
                    <strong>Fecha de entrega</strong>
                    <div t-field="o.delivery_date">2023-09-25</div>
                </div>
            </div>
            <div id="informations_2" class="row mb-4">
                <div class="col" t-if="o.invoice_origin" name="origin">
                    <strong>Origen</strong>
                    <div t-field="o.invoice_origin">SO123</div>
                </div>
                <div class="col" t-if="o.partner_id.ref" name="customer_code">
                    <strong>Código de cliente</strong>
                    <div t-field="o.partner_id.ref"/>
                </div>
                <div class="col" t-if="o.ref" name="reference">
                    <strong>Referencia del cliente</strong>
                    <div t-field="o.ref">INV/2023/00001</div>
                </div>
                <div class="col" t-if="o.invoice_incoterm_id" name="incoterm_id">
                    <strong>Incoterm</strong>
                    <div t-if="o.incoterm_location">
                        <span t-field="o.invoice_incoterm_id.code"/> <br/>
                        <span t-field="o.incoterm_location"/>
                    </div>
                    <div t-else="" t-field="o.invoice_incoterm_id.code" class="m-0"/>
                </div>
                
                <t t-set="albaranes_factura" t-value="o.invoice_line_ids.sale_line_ids.move_ids.picking_id.filtered(lambda p: p.state == 'done' and p.picking_type_id.code == 'outgoing')"/>
                <div class="col-auto mw-100 mb-2" t-if="albaranes_factura">
                    <strong>Albaranes:</strong>
                    <t t-foreach="albaranes_factura" t-as="picking">
                        <p t-field="picking.name" class="m-0"/>
                    </t>
                </div>
            </div>
        </xpath>
        <xpath expr="//table[@name='invoice_line_table']" position="before">
            <t t-set="ocultar_posiciones" t-value="1"/>
            <t t-foreach="o.invoice_line_ids" t-as="linea">
                <t t-if="linea.pos_palet">
                    <t t-set="ocultar_posiciones" t-value="0"/>
                </t>
            </t>
        </xpath>
        <xpath expr="//table[@name='invoice_line_table']//thead//tr[1]//th[@name='th_description']" position="before">
            <t t-if="ocultar_posiciones == 0">
                <th class="text-right">POS.</th>

            </t>
        </xpath>
        <xpath expr="//table[@name='invoice_line_table']//tbody//tr[1]//td[1]" position="before">
            <t t-if="ocultar_posiciones == 0">
                <td class="text-right">
                    <span t-field="line.pos_palet" />
                </td>

            </t>
        </xpath>
    </template>
</odoo>