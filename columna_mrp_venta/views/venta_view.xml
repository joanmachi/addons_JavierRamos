<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_form_inherit_mrp" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.mrp</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list/field[@name='discount']" position="after">
                <field name="mrp_production_ids" 
                    optional="show" />
            </xpath>
        </field>
    </record>

    <record id="sale_order_view_tree_inherit_mrp" model="ir.ui.view">
        <field name="name">sale.order.tree.inherit.mrp</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="all_fabricacion" optional="show"/>
            </xpath>
        </field>
    </record>


    <record id="sale_order_view_search_inherit_mrp" model="ir.ui.view">
        <field name="name">sale.order.search.inherit.mrp</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_view_search_inherit_quotation"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="all_fabricacion" string="Fabricaciones"/>
            </xpath>
        </field>
    </record>


</odoo>
