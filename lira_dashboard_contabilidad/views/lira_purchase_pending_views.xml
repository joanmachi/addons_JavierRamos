        <field name="qty_pedida" string="Cant. pedida" sum="Total pedida"
               help="Cantidad total pedida."/>
        <field name="qty_recibida" string="Cant. recibida" sum="Total recibida"
               help="Cantidad ya recibida en albarán."/>
        <field name="qty_pendiente" string="Cant. pendiente" sum="Total pendiente"
