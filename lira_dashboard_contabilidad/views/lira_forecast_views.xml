<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_lira_forecast_form" model="ir.ui.view">
    <field name="name">lira.forecast.form</field>
    <field name="model">lira.forecast</field>
    <field name="arch" type="xml">
      <form string="Previsión de liquidez" class="ld_form">
        <sheet>

          <!-- ══ CABECERA ═══════════════════════════════════════════════════════ -->
          <div class="ld_header">
            <div class="ld_header_left">
              <div class="ld_main_title ld_title_row">Previsión de Liquidez <widget name="lira_print_button" title="Previsión de Liquidez" line_model="lira.forecast.line"/></div>
              <div class="ld_main_subtitle">Proyección de ingresos y gastos para los próximos meses basada en el histórico contable y los pedidos pendientes de facturar. Los datos históricos provienen de las cuentas de ingresos y gastos.</div>
              <div class="ld_period_bar">
                <span class="fa fa-line-chart ld_icon_muted"/>
                <span class="ld_sep">Historial (meses) <i class="fa fa-info-circle text-muted ms-1" title="'Historial (meses)': Cuántos meses hacia atrás se toman como base histórica para calcular el promedio de ingresos y gastos."/></span>
                <field name="meses_hist" nolabel="1" class="ld_date_input"/>
                <span class="ld_sep ms-2">Previsión (meses) <i class="fa fa-info-circle text-muted ms-1" title="'Previsión (meses)': Cuántos meses futuros se proyectan, aplicando el promedio histórico más el incremento anual configurado."/></span>
                <field name="meses_prev" nolabel="1" class="ld_date_input"/>
                <span class="ld_sep ms-2">Incremento anual <i class="fa fa-info-circle text-muted ms-1" title="'Incremento anual': Porcentaje de crecimiento o inflación que se aplica a los ingresos y gastos históricos para calcular la previsión futura."/></span>
                <field name="incremento_pct" nolabel="1" class="ld_date_input"/>
                <span class="ld_sep">%</span>
                <button name="action_refresh" string="Actualizar" type="object"
                        class="ld_btn_primary" icon="fa-refresh"/>
              </div>
            </div>
            <div class="ld_header_kpis">
              <div class="ld_hkpi">
                <div class="ld_hkpi_label">
                  Ingresos previstos <i class="fa fa-info-circle text-muted ms-1" title="'Ingresos previstos': Suma de ingresos estimados para todos los meses proyectados, basados en el promedio histórico más el incremento anual."/>
                </div>
                <div class="ld_hkpi_value" style="color:#16a34a">
                  <field name="total_ingresos" readonly="1"/>
                </div>
              </div>
              <div class="ld_hkpi_sep"/>
              <div class="ld_hkpi">
                <div class="ld_hkpi_label">
                  Gastos previstos <i class="fa fa-info-circle text-muted ms-1" title="'Gastos previstos': Suma de gastos estimados para todos los meses proyectados, basados en el promedio histórico más el incremento anual."/>
                </div>
                <div class="ld_hkpi_value" style="color:#dc2626">
                  <field name="total_gastos" readonly="1"/>
                </div>
              </div>
              <div class="ld_hkpi_sep"/>
              <div class="ld_hkpi">
                <div class="ld_hkpi_label">Saldo neto total <i class="fa fa-info-circle text-muted ms-1" title="'Saldo neto total': Ingresos previstos menos gastos previstos en todo el período analizado. Positivo = la empresa genera más de lo que gasta."/></div>
                <div class="ld_hkpi_value">
                  <field name="saldo_total" readonly="1"/>
                </div>
              </div>
              <div class="ld_hkpi_sep"/>
              <div class="ld_hkpi">
                <div class="ld_hkpi_label">
                  Meses negativos <i class="fa fa-info-circle text-muted ms-1" title="'Meses negativos': Número de meses donde los gastos superan a los ingresos. Indica tensiones de liquidez: la empresa necesitará financiación extra esos meses."/>
                </div>
                <div class="ld_hkpi_value" style="color:#ca8a04">
                  <field name="meses_negativos" readonly="1"/>
                </div>
              </div>
              <div class="ld_hkpi_sep"/>
              <div class="ld_hkpi">
                <div class="ld_hkpi_label">Mes más crítico <i class="fa fa-info-circle text-muted ms-1" title="'Mes más crítico': El mes con el saldo negativo más alto (mayor diferencia entre gastos e ingresos). Es cuando más dinero faltará en caja."/></div>
                <div class="ld_hkpi_value" style="color:#dc2626">
                  <field name="mes_critico" readonly="1"/>
                </div>
              </div>
            </div>
          </div>

          <!-- ══ SALDO BANCOS HOY ══════════════════════════════════════════════ -->
          <div class="ld_section_header">
            <span class="ld_section_line"/>
            <span class="ld_section_title">
              <span class="fa fa-university me-2"/>
              Saldo actual por cuenta bancaria y caja
            </span>
          </div>

          <div class="ld_legend_strip">
            <i class="fa fa-info-circle ld_ls_ico"/>
            <strong class="ld_ls_title">¿Qué es esto?</strong>
            <span class="ld_ls_item">Saldo real disponible hoy en cada cuenta bancaria y de caja de la empresa. Fuente: movimientos contabilizados en cuentas de tipo Efectivo/Banco (asset_cash).</span>
          </div>

          <field name="banco_ids">
            <list string="Saldo bancos" create="0" delete="0">
              <field name="codigo_cuenta" string="Código"
                     help="Código contable de la cuenta bancaria o de caja." readonly="1"/>
              <field name="nombre_cuenta" string="Cuenta"
                     help="Nombre de la cuenta bancaria o de caja." readonly="1"/>
              <field name="saldo" string="Saldo (€)"
                     decoration-danger="saldo &lt; 0"
                     decoration-success="saldo &gt;= 0"
                     help="Saldo actual de la cuenta: suma de todos los apuntes contabilizados (débitos menos créditos)." readonly="1"/>
            </list>
          </field>

          <!-- ══ TABLA MENSUAL ══════════════════════════════════════════════════ -->
          <div class="ld_section_header">
            <span class="ld_section_line"/>
            <span class="ld_section_title">
              <span class="fa fa-calendar me-2"/>
              Evolución mensual — ingresos, gastos y saldo
            </span>
            <button name="action_open_lines" type="object"
                    class="ld_explore_btn"
                    title="Abrir tabla completa con buscador, filtros y agrupaciones de Odoo">
              <i class="fa fa-table me-1"/> Explorar tabla
            </button>
          </div>

          <!-- ══ AVISO DE CEROS ════════════════════════════════════════════════ -->
          <div class="ld_legend_strip" invisible="not tiene_ceros">
            <i class="fa fa-info-circle ld_ls_ico"/>
            <strong class="ld_ls_title">¿Por qué aparecen 0,00?</strong>
            <span class="ld_ls_item">Ingresos = 0: sin facturas de cliente ni vencimientos pendientes ese mes</span><span class="ld_ls_item">Gastos = 0: sin facturas de proveedor ni apuntes de gastos en ese mes</span>
          </div>

          <field name="line_ids">
            <list string="Previsión mensual" create="0" delete="0"
                  decoration-info="tipo == 'prevision'"
                  decoration-danger="saldo_mes &lt; 0"
                  decoration-success="saldo_mes &gt;= 0 and tipo == 'historico'">
              <field name="mes" string="Mes" readonly="1" class="fw-bold"
                     help="Mes al que corresponde la fila. Los meses históricos (verde) son datos reales; los de previsión (azul) son proyecciones."/>
              <field name="tipo" string="Tipo" widget="badge"
                     decoration-success="tipo == 'historico'"
                     decoration-info="tipo == 'prevision'" readonly="1"
                     help="Histórico = dato real de la contabilidad. Previsión = estimación calculada a partir del promedio histórico."/>
              <field name="ingresos" string="Ingresos (€)" readonly="1"
                     help="Ingresos del mes: histórico = cuentas 7xx reales; previsión = promedio histórico × (1 + incremento anual)."/>
              <field name="gastos" string="Gastos (€)" readonly="1"
                     help="Gastos del mes: histórico = cuentas 6xx reales; previsión = promedio histórico × (1 + incremento anual)."/>
              <field name="saldo_mes" string="Saldo mes (€)" readonly="1"
                     decoration-danger="saldo_mes &lt; 0"
                     decoration-success="saldo_mes &gt;= 0"
                     help="Ingresos menos gastos del mes. En rojo = ese mes la empresa gasta más de lo que ingresa."/>
              <field name="saldo_acumulado" string="Saldo acum. (€)" readonly="1"
                     decoration-danger="saldo_acumulado &lt; 0"
                     decoration-success="saldo_acumulado &gt;= 0"
                     help="Saldo neto acumulado desde el primer mes analizado hasta este. En rojo = en ese punto la empresa habrá gastado más de lo que ha ingresado en total."/>
            </list>
          </field>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_lira_forecast_open" model="ir.actions.server">
    <field name="name">Previsión de liquidez Lira</field>
    <field name="model_id" ref="model_lira_forecast"/>
    <field name="state">code</field>
    <field name="code">action = model.action_open()</field>
  </record>

  <!-- ══ LISTA lira.forecast.line ═══════════════════════════════════════════ -->
  <record id="view_lira_forecast_line_list2" model="ir.ui.view">
    <field name="name">lira.forecast.line.list2</field>
    <field name="model">lira.forecast.line</field>
    <field name="arch" type="xml">
      <list string="Previsión mensual" create="0" delete="0" edit="0"
            decoration-info="tipo == 'prevision'"
            decoration-danger="saldo_mes &lt; 0"
            decoration-success="saldo_mes &gt;= 0 and tipo == 'historico'">
        <field name="mes" string="Mes"
               help="Mes al que corresponde la fila."/>
        <field name="tipo" string="Tipo" widget="badge"
               decoration-success="tipo == 'historico'"
               decoration-info="tipo == 'prevision'"
               help="Histórico: dato real contable. Previsión: estimación calculada."/>
        <field name="ingresos" string="Ingresos (€)" sum="Total ingresos"
               help="Ingresos del mes (reales o estimados según tipo)."/>
        <field name="gastos" string="Gastos (€)" sum="Total gastos"
               help="Gastos del mes (reales o estimados según tipo)."/>
        <field name="saldo_mes" string="Saldo mes (€)" sum="Saldo total"
               decoration-danger="saldo_mes &lt; 0" decoration-success="saldo_mes &gt;= 0"
               help="Ingresos − Gastos del mes."/>
        <field name="saldo_acumulado" string="Saldo acum. (€)"
               decoration-danger="saldo_acumulado &lt; 0" decoration-success="saldo_acumulado &gt;= 0"
               help="Saldo neto acumulado desde el primer mes."/>
        <button name="action_open_source" type="object" icon="fa-external-link"
                string="Ver apuntes del mes"
                invisible="tipo == 'prevision'"
                title="Abrir los apuntes contables reales de ingresos/gastos de este mes"/>
      </list>
    </field>
  </record>

  <!-- ══ BUSCADOR lira.forecast.line ════════════════════════════════════════ -->
  <record id="view_lira_forecast_line_search" model="ir.ui.view">
    <field name="name">lira.forecast.line.search</field>
    <field name="model">lira.forecast.line</field>
    <field name="arch" type="xml">
      <search string="Buscar en previsión de liquidez">
        <field name="mes" string="Mes"/>
        <field name="tipo" string="Tipo"/>
        <separator/>
        <filter name="historico" string="Datos históricos" domain="[('tipo','=','historico')]"/>
        <filter name="prevision" string="Previsiones"      domain="[('tipo','=','prevision')]"/>
        <separator/>
        <filter name="saldo_pos"   string="Saldo mes &gt; 0"       domain="[('saldo_mes','&gt;',0)]"/>
        <filter name="saldo_neg"   string="Saldo mes &lt; 0 (déficit)"  domain="[('saldo_mes','&lt;',0)]"/>
        <filter name="acum_neg"    string="Saldo acum. negativo" domain="[('saldo_acumulado','&lt;',0)]"/>
        <separator/>
        <filter name="ing_10k"   string="Ingresos &gt; 10.000 €" domain="[('ingresos','&gt;',10000)]"/>
        <filter name="gas_10k"   string="Gastos &gt; 10.000 €"   domain="[('gastos','&gt;',10000)]"/>
        <group expand="1" string="Agrupar por">
          <filter name="group_tipo"    string="Tipo"           context="{'group_by': 'tipo'}"/>
          <filter name="group_mes"     string="Mes"            context="{'group_by': 'mes'}"/>
          <filter name="group_ing"     string="Ingresos"       context="{'group_by': 'ingresos'}"/>
          <filter name="group_gastos"  string="Gastos"         context="{'group_by': 'gastos'}"/>
          <filter name="group_saldo"   string="Saldo mes"      context="{'group_by': 'saldo_mes'}"/>
          <filter name="group_acum"    string="Saldo acumulado" context="{'group_by': 'saldo_acumulado'}"/>
        </group>
      </search>
    </field>
  </record>

</odoo>
