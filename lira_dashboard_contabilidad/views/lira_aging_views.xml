<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ══ FORMULARIO Antigüedad ══════════════════════════════════════════════ -->
  <record id="view_lira_aging_form" model="ir.ui.view">
    <field name="name">lira.aging.form</field>
    <field name="model">lira.aging</field>
    <field name="arch" type="xml">
      <form string="Antigüedad de saldos de clientes" class="ld_form">
        <sheet>

          <div class="ld_header">
            <div class="ld_header_left">
              <div class="ld_main_title ld_title_row">Antigüedad de Saldos <widget name="lira_print_button" title="Antigüedad de Saldos" line_model="lira.aging.line"/></div>
              <div class="ld_main_subtitle">Facturas de cliente pendientes de cobro clasificadas por tramos de antigüedad. Detecta qué clientes acumulan deuda vencida y cuánto llevan sin pagar.</div>
              <div class="ld_period_bar">
                <span class="fa fa-clock-o ld_icon_muted"/>
                <button name="action_refresh" string="Actualizar" type="object"
                        class="ld_btn_primary" icon="fa-refresh"/>
              </div>
            </div>
            <div class="ld_header_kpis">
              <div class="ld_hkpi">
                <div class="ld_hkpi_label">Total pendiente <i class="fa fa-info-circle text-muted ms-1" title="Suma total de todas las facturas de cliente sin cobrar, tanto corrientes como vencidas."/></div>
                <div class="ld_hkpi_value"><field name="total_pendiente" readonly="1"/></div>
              </div>
              <div class="ld_hkpi_sep"/>
              <div class="ld_hkpi">
                <div class="ld_hkpi_label">Corriente <i class="fa fa-info-circle text-muted ms-1" title="Importe de facturas que aún no han vencido: el cliente está dentro del plazo de pago acordado."/></div>
                <div class="ld_hkpi_value" style="color:#16a34a"><field name="importe_corriente" readonly="1"/></div>
              </div>
              <div class="ld_hkpi_sep"/>
              <div class="ld_hkpi">
                <div class="ld_hkpi_label">Total vencido <i class="fa fa-info-circle text-muted ms-1" title="Suma de todos los importes cuya fecha de vencimiento ya pasó y siguen sin cobrar."/></div>
                <div class="ld_hkpi_value" style="color:#ca8a04"><field name="total_vencido" readonly="1"/></div>
              </div>
              <div class="ld_hkpi_sep"/>
              <div class="ld_hkpi">
                <div class="ld_hkpi_label">+90 días (crítico) <i class="fa fa-info-circle text-muted ms-1" title="Importe vencido hace más de 90 días. Alto riesgo de impago definitivo."/></div>
                <div class="ld_hkpi_value" style="color:#dc2626"><field name="importe_critico" readonly="1"/></div>
              </div>
              <div class="ld_hkpi_sep"/>
              <div class="ld_hkpi">
                <div class="ld_hkpi_label">Clientes vencidos <i class="fa fa-info-circle text-muted ms-1" title="Número de clientes distintos que tienen al menos una factura vencida sin cobrar."/></div>
                <div class="ld_hkpi_value"><field name="clientes_vencidos" readonly="1"/></div>
              </div>
            </div>
          </div>

          <div class="ld_cta_panel">
            <div class="ld_cta_icon"><i class="fa fa-table"/></div>
            <div class="ld_cta_text">
              <strong>Ver saldo por cliente y tramo de antigüedad</strong>
              <span>Abre la tabla con el buscador nativo de Odoo: filtra por cliente, NIF, ciudad o país; agrupa por tramo.</span>
            </div>
            <button name="action_ver_tabla" string="Ver tabla" type="object"
                    class="ld_btn_primary" icon="fa-search"/>
          </div>

        </sheet>
      </form>
    </field>
  </record>

  <!-- ══ LISTA lira.aging.line ══════════════════════════════════════════════ -->
  <record id="view_lira_aging_line_list" model="ir.ui.view">
    <field name="name">lira.aging.line.list</field>
    <field name="model">lira.aging.line</field>
    <field name="arch" type="xml">
      <list string="Antigüedad de saldos" create="0" delete="0" edit="0"
            decoration-danger="tramo_mas &gt; 0"
            decoration-warning="tramo_90 &gt; 0 and tramo_mas == 0"
            decoration-success="tramo_30 == 0 and tramo_60 == 0 and tramo_90 == 0 and tramo_mas == 0">
        <field name="rank" string="#" width="44"
               help="Posición en el ranking ordenado de mayor a menor deuda total."/>
        <field name="partner_id" string="Cliente"
               help="Cliente con facturas pendientes de cobro."/>
        <field name="partner_vat" string="NIF/CIF" optional="hide"
               help="Número de identificación fiscal del cliente."/>
        <field name="partner_city" string="Ciudad" optional="hide"
               help="Ciudad del cliente."/>
        <field name="partner_country_id" string="País" optional="hide"
               help="País del cliente."/>
        <field name="partner_ref" string="Ref. cliente" optional="hide"
               help="Referencia interna del cliente."/>
        <field name="partner_email" string="Email" optional="hide"
               help="Email de contacto del cliente."/>
        <field name="partner_phone" string="Teléfono" optional="hide"
               help="Teléfono del cliente."/>
        <field name="total" string="Total (€)" sum="Total pendiente"
               help="Suma de todas las facturas pendientes de este cliente = corriente + 1-30 + 31-60 + 61-90 + +90 días."/>
        <field name="corriente" string="Corriente (€)" sum="Total"
               help="Facturas no vencidas (dentro del plazo de pago acordado)."/>
        <field name="tramo_30" string="1–30 d (€)" sum="Total"
               help="Facturas vencidas entre 1 y 30 días."/>
        <field name="tramo_60" string="31–60 d (€)" sum="Total"
               help="Facturas vencidas entre 31 y 60 días."/>
        <field name="tramo_90" string="61–90 d (€)" sum="Total"
               help="Facturas vencidas entre 61 y 90 días."/>
        <field name="tramo_mas" string="+90 d (€)" sum="Total"
               help="Facturas vencidas hace más de 90 días (crítico)."/>
        <field name="num_facturas" string="Facturas" sum="Total"
               help="Número de facturas pendientes del cliente."/>
        <field name="dias_max" string="Días máx." avg="Media"
               help="Mayor antigüedad entre todas las facturas vencidas del cliente."/>
        <field name="user_id" column_invisible="1"/>
        <button name="action_open_source" type="object" icon="fa-external-link"
                string="Ver facturas pendientes en Odoo"
                title="Abrir facturas pendientes de este cliente en Contabilidad"/>
      </list>
    </field>
  </record>

  <!-- ══ BUSCADOR lira.aging.line — filtros profundos ══════════════════════ -->
  <record id="view_lira_aging_line_search" model="ir.ui.view">
    <field name="name">lira.aging.line.search</field>
    <field name="model">lira.aging.line</field>
    <field name="arch" type="xml">
      <search string="Buscar en antigüedad de saldos">
        <field name="partner_id" string="Cliente / NIF / Ciudad / País"
               filter_domain="['|','|','|','|',
                               ('partner_id.name','ilike',self),
                               ('partner_id.vat','ilike',self),
                               ('partner_id.city','ilike',self),
                               ('partner_id.ref','ilike',self),
                               ('partner_id.country_id.name','ilike',self)]"/>
        <field name="partner_vat" string="NIF/CIF"/>
        <field name="partner_city" string="Ciudad"/>
        <field name="partner_country_id" string="País"/>
        <field name="partner_email" string="Email"/>
        <field name="partner_phone" string="Teléfono"/>
        <separator/>
        <filter name="con_vencido" string="Con deuda vencida"
                domain="[('tramo_30','>',0)]"/>
        <filter name="criticos" string="Críticos (+90 días)"
                domain="[('tramo_mas','>',0)]"/>
        <filter name="con_90"  string="Con 61–90 días" domain="[('tramo_90','>',0)]"/>
        <filter name="con_60"  string="Con 31–60 días" domain="[('tramo_60','>',0)]"/>
        <filter name="con_30"  string="Con 1–30 días"  domain="[('tramo_30','>',0)]"/>
        <filter name="solo_corriente" string="Solo corriente"
                domain="[('corriente','>',0),('tramo_30','=',0),('tramo_60','=',0),('tramo_90','=',0),('tramo_mas','=',0)]"/>
        <separator/>
        <filter name="total_1k"   string="Total &gt; 1.000 €"  domain="[('total','>',1000)]"/>
        <filter name="total_5k"   string="Total &gt; 5.000 €"  domain="[('total','>',5000)]"/>
        <filter name="total_10k"  string="Total &gt; 10.000 €" domain="[('total','>',10000)]"/>
        <separator/>
        <filter name="mas_3_fact"   string="≥ 3 facturas"  domain="[('num_facturas','>=',3)]"/>
        <filter name="mas_60_dias"  string="Días máx. &gt; 60" domain="[('dias_max','>',60)]"/>
        <separator/>
        <filter name="top10" string="Top 10" domain="[('rank','&lt;=',10)]"/>
        <filter name="top25" string="Top 25" domain="[('rank','&lt;=',25)]"/>
        <group expand="1" string="Agrupar por">
          <filter name="group_partner"  string="Cliente"       context="{'group_by': 'partner_id'}"/>
          <filter name="group_rank"     string="Ranking"       context="{'group_by': 'rank'}"/>
          <filter name="group_total"    string="Total pdte."   context="{'group_by': 'total'}"/>
          <filter name="group_corr"     string="Corriente"     context="{'group_by': 'corriente'}"/>
          <filter name="group_30"       string="1–30 días"     context="{'group_by': 'tramo_30'}"/>
          <filter name="group_60"       string="31–60 días"    context="{'group_by': 'tramo_60'}"/>
          <filter name="group_90"       string="61–90 días"    context="{'group_by': 'tramo_90'}"/>
          <filter name="group_mas"      string="+90 días"      context="{'group_by': 'tramo_mas'}"/>
          <filter name="group_num_fact" string="Nº facturas"   context="{'group_by': 'num_facturas'}"/>
          <filter name="group_dias_max" string="Días máx."     context="{'group_by': 'dias_max'}"/>
        </group>
      </search>
    </field>
  </record>

  <!-- ══ ACCIÓN DEL MENÚ ════════════════════════════════════════════════════ -->
  <record id="action_lira_aging" model="ir.actions.server">
    <field name="name">Antigüedad de saldos Lira</field>
    <field name="model_id" ref="model_lira_aging"/>
    <field name="state">code</field>
    <field name="code">action = model.action_open()</field>
  </record>

</odoo>
