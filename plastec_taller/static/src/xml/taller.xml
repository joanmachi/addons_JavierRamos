<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
   <t t-name="plastec_taller.menu_desplegable"
      t-inherit="mrp_workorder.MrpDisplayMenuDialog" t-inherit-mode="extension">
        <xpath expr="//button[@name='action_scrap']" position="before">
            <button class="btn btn-outline-secondary d-flex justify-content-between align-items-center p-3 fs-3"
                     name="crear_albaran_palet"
                     t-on-click="() => this.callAction('action_add_albaran_palet')">
               Palet completo <i class="oi oi-chevron-right"/>
            </button>
       </xpath>
   </t>
</templates>