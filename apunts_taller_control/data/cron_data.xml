<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="cron_alertar_fichajes_largos" model="ir.cron">
        <field name="name">Apunts taller: alertar fichajes >16h</field>
        <field name="model_id" ref="model_apunts_taller_control"/>
        <field name="state">code</field>
        <field name="code">model.cron_alertar_fichajes_largos()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
    </record>

    <record id="cron_bloquear_fichajes_largos" model="ir.cron">
        <field name="name">Apunts taller: bloquear empleados con fichaje >9h</field>
        <field name="model_id" ref="model_apunts_taller_control"/>
        <field name="state">code</field>
        <field name="code">model.cron_bloquear_fichajes_largos()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>

    <record id="cron_bloquear_inactividad" model="ir.cron">
        <field name="name">Apunts taller: bloquear empleados sin fichaje >5 min</field>
        <field name="model_id" ref="model_apunts_taller_control"/>
        <field name="state">code</field>
        <field name="code">model.cron_bloquear_inactividad()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>

</odoo>
