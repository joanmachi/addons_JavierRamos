<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="apunts_sobre_fichaje_wizard_form" model="ir.ui.view">
        <field name="name">apunts.sobre.fichaje.wizard.form</field>
        <field name="model">apunts.sobre.fichaje.wizard</field>
        <field name="arch" type="xml">
            <form string="Sobre-fichaje detectado">
                <sheet>
                    <div class="alert alert-warning">
                        <i class="fa fa-exclamation-triangle me-1"/>
                        <strong>Ya estás fichado en otra/s OF.</strong>
                        Decide qué hacer antes de arrancar la nueva.
                    </div>
                    <group>
                        <field name="employee_name" readonly="1"/>
                        <field name="barcode_nueva" invisible="1"/>
                        <field name="employee_int_id" invisible="1"/>
                        <field name="res_id_int" invisible="1"/>
                    </group>
                    <separator string="OFs en las que ya estás fichado:"/>
                    <field name="linea_ids" nolabel="1">
                        <list editable="bottom" create="0" delete="0">
                            <field name="of_id" string="OF" readonly="1"/>
                            <field name="ot_name" string="OT" readonly="1"/>
                            <field name="inicio" string="Fichado desde" readonly="1"/>
                            <button name="action_ir_a_of" type="object"
                                    string="Ir a esta OF (taller)"
                                    icon="fa-external-link"
                                    class="btn btn-sm btn-primary"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_mantener_doble" type="object"
                            string="Continuar y arrancar otra OF (mantengo las anteriores)"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
