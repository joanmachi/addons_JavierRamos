<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="apunts_fin_jornada_wizard_form" model="ir.ui.view">
        <field name="name">apunts.fin.jornada.wizard.form</field>
        <field name="model">apunts.fin.jornada.wizard</field>
        <field name="arch" type="xml">
            <form string="Fin de jornada">
                <sheet>
                    <div class="alert alert-info">
                        <i class="fa fa-info-circle me-1"/>
                        Cierra todos tus fichajes abiertos del día y registra
                        el nº de piezas hechas en la última OF.
                    </div>
                    <group>
                        <field name="pin" password="True" placeholder="Tu PIN"/>
                        <field name="employee_id" readonly="1" invisible="not employee_id"/>
                    </group>
                    <button name="action_buscar_pin" type="object"
                            string="Ver mi resumen" class="btn-secondary"
                            invisible="employee_id"/>
                    <separator string="Resumen del día"/>
                    <field name="resumen_html" nolabel="1"/>
                    <separator string="Piezas hechas en cada OF abierta" invisible="not employee_id"/>
                    <field name="linea_ids" nolabel="1" invisible="not employee_id">
                        <list editable="bottom" create="0" delete="0">
                            <field name="of_name" string="OF" readonly="1"/>
                            <field name="ot_name" string="OT" readonly="1"/>
                            <field name="inicio" string="Inicio" readonly="1"/>
                            <field name="qty_piezas" string="Piezas hechas"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_confirmar_fin_jornada" type="object"
                            string="Confirmar y salir" class="btn-primary"
                            invisible="not employee_id"/>
                    <button special="cancel" string="Cancelar"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="apunts_fin_jornada_action" model="ir.actions.act_window">
        <field name="name">Fin de jornada</field>
        <field name="res_model">apunts.fin.jornada.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
