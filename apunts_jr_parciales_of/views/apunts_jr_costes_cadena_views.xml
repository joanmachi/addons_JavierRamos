<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_apunts_jr_costes_cadena_form" model="ir.ui.view">
        <field name="name">apunts.jr.costes.cadena.form</field>
        <field name="model">apunts.jr.costes.cadena</field>
        <field name="arch" type="xml">
            <form string="Costes cadena" create="false" edit="false" delete="false">
                <sheet>
                    <div class="oe_title mb-3">
                        <h2>Cadena: <field name="raiz_name" readonly="1" nolabel="1" class="oe_inline"/></h2>
                    </div>

                    <!-- Campos ocultos necesarios para decoraciones y widget monetary -->
                    <field name="cadena_margin_state" invisible="1"/>
                    <field name="currency_id" invisible="1"/>

                    <!-- KPI cards — misma estructura que Coste OF -->
                    <div class="row g-3 mb-3">
                        <div class="col-md-3 col-sm-6">
                            <div class="card border-success h-100">
                                <div class="card-body text-center">
                                    <div class="text-muted small text-uppercase">Venta</div>
                                    <div class="display-6 fw-bold text-success">
                                        <field name="cadena_sale_amount" nolabel="1" readonly="1" widget="monetary"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Importe total del pedido de venta de toda la cadena.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <div class="card border-warning h-100">
                                <div class="card-body text-center">
                                    <div class="text-muted small text-uppercase">En curso (real)</div>
                                    <div class="display-6 fw-bold text-warning">
                                        <field name="cadena_cost_total_real" nolabel="1" readonly="1" widget="monetary"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Material + operario + máquina ya invertidos en la cadena.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <div class="card border-primary h-100">
                                <div class="card-body text-center">
                                    <div class="text-muted small text-uppercase">Coste teórico</div>
                                    <div class="display-6 fw-bold text-primary">
                                        <field name="cadena_cost_total_planned" nolabel="1" readonly="1" widget="monetary"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Coste previsto total según BoM y routing de toda la cadena.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <div class="card border-info h-100">
                                <div class="card-body text-center">
                                    <div class="text-muted small text-uppercase">Margen actual</div>
                                    <div class="display-6 fw-bold">
                                        <field name="cadena_margin" nolabel="1" readonly="1" widget="monetary"
                                               decoration-success="cadena_margin_state == 'green'"
                                               decoration-warning="cadena_margin_state == 'amber'"
                                               decoration-danger="cadena_margin_state == 'red'"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Venta − coste real. Verde ≥ 20%, ámbar 0–20%, rojo &lt; 0%.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <h3 class="mt-3">Desglose por concepto</h3>
                    <table class="table table-bordered align-middle mt-2">
                        <thead>
                            <tr>
                                <th class="text-start">Concepto</th>
                                <th class="text-end">Teórico</th>
                                <th class="text-end">Real</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-start">
                                    <div class="fw-bold">MP (Materia Prima)</div>
                                    <div class="small text-muted">
                                        Suma de la materia prima de todas las OFs de la cadena.
                                    </div>
                                </td>
                                <td class="text-end h4 mb-0">
                                    <field name="cadena_mat_planned" nolabel="1" readonly="1" widget="monetary"/>
                                </td>
                                <td class="text-end h4 mb-0">
                                    <field name="cadena_mat_real" nolabel="1" readonly="1" widget="monetary"/>
                                </td>
                            </tr>
                            <tr class="table-secondary">
                                <td class="text-start">
                                    <div class="fw-bold">Tiempo de fabricación</div>
                                    <div class="small text-muted">
                                        Suma de minutos de todas las OFs (teórico = routing, real = fichado).
                                    </div>
                                </td>
                                <td class="text-end h4 mb-0">
                                    <field name="cadena_min_planned" nolabel="1" readonly="1" widget="float_time"/>
                                </td>
                                <td class="text-end h4 mb-0">
                                    <field name="cadena_min_real" nolabel="1" readonly="1" widget="float_time"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-start">
                                    <div class="fw-bold ps-4">↳ Coste operario</div>
                                    <div class="small text-muted ps-4">
                                        Suma del coste de mano de obra de todas las OFs.
                                    </div>
                                </td>
                                <td class="text-end h4 mb-0">
                                    <field name="cadena_mo_planned" nolabel="1" readonly="1" widget="monetary"/>
                                </td>
                                <td class="text-end h4 mb-0">
                                    <field name="cadena_mo_real" nolabel="1" readonly="1" widget="monetary"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-start">
                                    <div class="fw-bold ps-4">↳ Coste máquina</div>
                                    <div class="small text-muted ps-4">
                                        Suma del coste de máquina (centros de trabajo) de todas las OFs.
                                    </div>
                                </td>
                                <td class="text-end h4 mb-0">
                                    <field name="cadena_machine_planned" nolabel="1" readonly="1" widget="monetary"/>
                                </td>
                                <td class="text-end h4 mb-0">
                                    <field name="cadena_machine_real" nolabel="1" readonly="1" widget="monetary"/>
                                </td>
                            </tr>
                            <tr class="table-active">
                                <td class="text-start fw-bold">TOTAL</td>
                                <td class="text-end h4 mb-0 fw-bold">
                                    <field name="cadena_cost_total_planned" nolabel="1" readonly="1" widget="monetary"/>
                                </td>
                                <td class="text-end h4 mb-0 fw-bold">
                                    <field name="cadena_cost_total_real" nolabel="1" readonly="1" widget="monetary"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <h3 class="mt-4">OFs de la cadena</h3>
                    <field name="of_ids" nolabel="1" readonly="1">
                        <list string="OFs de la cadena" create="0" delete="0" edit="0">
                            <field name="apunts_lote_index" string="Lote" optional="show"/>
                            <field name="name" string="Nº OF"/>
                            <field name="state" widget="badge"
                                   decoration-success="state == 'done'"
                                   decoration-warning="state in ('confirmed','progress','to_close')"
                                   decoration-danger="state == 'cancel'"
                                   optional="show"/>
                            <field name="product_qty" string="Cant. planif." widget="integer" optional="show"/>
                            <field name="apunts_qty_done" string="Hecho" widget="integer" optional="show"/>
                            <field name="apunts_sale_amount" string="Venta (€)" sum="Total venta" widget="monetary"/>
                            <field name="apunts_mat_real_total" string="MP real (€)" sum="Total MP" widget="monetary" optional="show"/>
                            <field name="apunts_mo_real_total" string="MO real (€)" sum="Total MO" widget="monetary" optional="show"/>
                            <field name="apunts_machine_real_total" string="Máquina real (€)" sum="Total máquina" widget="monetary" optional="show"/>
                            <field name="apunts_cost_total_real" string="Total real (€)" sum="Total" widget="monetary"/>
                            <field name="apunts_cost_total_planned" string="Coste teórico (€)" sum="Total teórico" widget="monetary" optional="show"/>
                            <field name="company_currency_id" column_invisible="1"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
