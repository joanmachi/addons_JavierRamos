<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_workorder_qty_wizard_form" model="ir.ui.view">
        <field name="name">workorder.qty.wizard.form</field>
        <field name="model">workorder.qty.wizard</field>
        <field name="arch" type="xml">
            <form string="Validar Cantidad">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Introduzca la cantidad a validar de la orden: <strong><field name="workorder_id" readonly="1" options="{'no_open': True}"/></strong>.
                    </div>
                    <group>
                        <group>
                            <field name="qty_to_process" string="Pendiente de validar"/>
                            <field name="new_qty" string="Cantidad a validar"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Confirmar" name="action_confirm" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
