                    <filter string="MONTAJE" name="filter_by_workcenter_22" invisible="1"
                            domain="[('workorder_ids.workcenter_id', 'in', [22])]"/>


                    <filter string="TRABAJOS MANUALES" name="filter_by_workcenter_32" invisible="1"
                            domain="[('workorder_ids.workcenter_id', 'in', [32])]"/>


                    <filter string="SERVICIOS EXTERNOS" name="filter_by_workcenter_36" invisible="1"
                            domain="[('workorder_ids.workcenter_id', 'in', [36])]"/>


