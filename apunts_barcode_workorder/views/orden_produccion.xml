                    <filter string="PINACHO" name="filter_by_workcenter_18" invisible="1"
                            domain="[('workorder_ids.workcenter_id', 'in', [18])]"/>


                    <filter string="CAD" name="filter_by_workcenter_19" invisible="1"
                            domain="[('workorder_ids.workcenter_id', 'in', [19])]"/>


                    <filter string="DYE" name="filter_by_workcenter_20" invisible="1"
