                </xpath>
            </field>
        </record>

<record id="mrp_workorder_fichajes_kanban_view_inherit" model="ir.ui.view">
        <field name="name">stock.picking.type.kanban.inherit</field>
        <field name="model">stock.picking.type</field>
        <field name="inherit_id" ref="stock_barcode.stock_picking_type_kanban"/>
        <field name="arch" type="xml">
                <xpath expr="//div[hasclass('rounded-pill')]" position="replace">
                           <div class="badge rounded-pill bg-secondary float-end align-self-center p-1 px-2 fs-6" t-if="record.count_picking_ready.value > 0"
                                 t-attf-class="{{ record.count_picking_ready.value == 0 ? 'text-muted' : 'fw-bold' }}"
                                 name="get_action_picking_tree_ready_kanban" type="object">
                                <span name="pickings_count"><field name="count_picking_ready"/></span> 
                            </div>
                </xpath>
           
        </field>
    </record>

</odoo>
