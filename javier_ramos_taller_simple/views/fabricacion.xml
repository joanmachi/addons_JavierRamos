<odoo>
  <record id="view_production_form" model="ir.ui.view">
    <field name="name">mrp.production.form</field>
    <field name="model">mrp.production</field>
    <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='log_note']" position="replace">
      </xpath>
      <xpath expr="//field[@name='user_id']" position="after">
        <field name="log_note"/>
      </xpath>
      <xpath expr="//div[@name='bom_div']" position="after">
        <field name="x_studio_compra"/>
        <field name="x_studio_venta"/>
      </xpath>
    </field>
    </record>
  <record id="view_workorder_list" model="ir.ui.view">
    <field name="name">mrp.workorder.list</field>
    <field name="model">mrp.workorder</field>
    <field name="inherit_id" ref="mrp.mrp_production_workorder_tree_view"/>
    <field name="arch" type="xml">
		<xpath expr="//field[@name='production_id']" position="attributes">
        <attribute name="width">130px</attribute>
      </xpath>

      <xpath expr="//field[@name='sale_id']" position="attributes">
        <attribute name="column_invisible">True</attribute>
      </xpath>
      <xpath expr="//field[@name='partner_id']" position="attributes">
        <attribute name="column_invisible">True</attribute>
      </xpath>
      <xpath expr="//field[@name='commitment_date']" position="attributes">
        <attribute name="column_invisible">True</attribute>
      </xpath>
      <xpath expr="//field[@name='client_order_ref']" position="attributes">
        <attribute name="column_invisible">True</attribute>
      </xpath>
    </field>
    </record>
  </odoo>
  
  