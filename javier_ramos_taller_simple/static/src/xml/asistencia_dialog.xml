<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="javier_ramos_taller_simple.AsistenciaDialog">
    <div class="o_tablet_popups">
        <Dialog size="'md'" title="props.title" modalRef="modalRef">
            <t t-set-slot="header">
                <div class="d-flex flex w-100">
                    <div class="h4 align-self-end" t-esc="props.title"/>
                    <div t-on-click="cancel" type="button" class="btn-close" aria-label="Close"/>
                </div>
            </t>
          
            <div class="o_workorder_bar_content">
                <div class="row">
                    <span class="col-12 text-center" style="font-size:4rem;">Introduce tu PIN</span>
                    <span name="pin" class="o_field_widget text-center col-12">
                         <input id="aux_pin" class="o_input"  style="width:73%; font-size: 4rem;"/>
                    </span>
                    
                </div>
                
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary me-2" t-on-click="validate" >Aceptar</button>
            </t>
        </Dialog>
        </div>
    </t>
</templates>
