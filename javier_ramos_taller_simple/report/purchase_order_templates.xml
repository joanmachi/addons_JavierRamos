<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template
        id="report_purchaseorder_document"
        inherit_id="purchase.report_purchaseorder_document">
   
        <xpath expr="//td[@id='secondary_unit']" position="replace">
            <td id="secondary_unit" class="text-end">
                <span t-field="line.secondary_uom_qty" />
                <span t-field="line.secondary_uom_id.uom_id.name" />
            </td>
        </xpath>
    </template>
</odoo>
