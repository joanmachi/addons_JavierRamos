<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_mrporder_custom" inherit_id="mrp.report_mrporder" priority="2">
        <xpath expr="//table[hasclass('table')]" position="replace">
            <table class="table table-sm">
                <tr>
                    <th><strong>Operación</strong></th>
                    <th><strong>Centro de trabajo</strong></th>
                    <th><strong>Duración (minutos)</strong></th>
                    <th><strong>Duración unitaria (minutos)</strong></th>
                    <th style="width:30%" t-if="False"><strong>Código de barras</strong></th>
                </tr>
                <tr t-foreach="o.workorder_ids" t-as="line2">
                    <td><span t-field="line2.name">Assembling</span></td>
                    <td><span t-field="line2.workcenter_id.name">Center A</span></td>
                    <td>
                        <span t-if="line2.operation_id"  t-esc="o.product_qty * line2.operation_id.time_cycle">58</span>
                    </td>
                 
                    <td >
                        <span t-if="line2.operation_id" t-field="line2.operation_id.time_cycle">58</span>
                    </td>
                    <td  t-if="False">
                        <span t-field="line2.barcode" t-options="{'widget': 'barcode', 'width': 600, 'height': 100, 'img_style': 'width:100%;height:35px'}">987654321098</span>
                    </td>
                </tr>
            </table>
        </xpath>
            
  
    </template>
   
</odoo>
