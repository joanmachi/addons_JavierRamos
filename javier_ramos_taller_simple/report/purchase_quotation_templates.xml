<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template
        id="report_purchasequotation_document"
        inherit_id="purchase.report_purchasequotation_document"
    >
 
        <xpath expr="//td[@id='secondary_unit']" position="replace">
            <td id="secondary_unit" class="text-end">
                <span t-field="order_line.secondary_uom_qty" />
                <span t-field="order_line.secondary_uom_id.uom_id.name" />
            </td>
        </xpath>
    </template>
</odoo>
