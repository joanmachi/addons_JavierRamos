<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="etiqueta_albaran">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-if="o.picking_type_id.barcode == 'WHOUT'">
                    <t t-call="javier_ramos_taller_simple.etiqueta_albaran_entrega_document" t-lang="o.partner_id.lang"/>
                </t>
                <t t-if="o.picking_type_id.barcode == 'WHIN'">
                    <t t-call="javier_ramos_taller_simple.etiqueta_albaran_recepcion_document" t-lang="o.partner_id.lang"/>
                </t>
            </t>
        </t>
    </template>

    <!-- ── EXPEDICIÓN ─────────────────────────────────────────────────────── -->
    <template id="etiqueta_albaran_entrega_document">
        <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>
        <t t-foreach="o.move_ids_without_package" t-as="linea_albaran">

            <!-- Resolver cliente: sale_line > partner directo del picking -->
            <t t-set="cliente_expedicion" t-value="linea_albaran.sale_line_id.order_id.partner_id or o.partner_id"/>

            <div class="page article" style="font-family: Arial, sans-serif; box-sizing: border-box; padding: 3mm;">
                <table style="width: 100%; border-collapse: collapse; table-layout: fixed;">

                    <!-- CABECERA + número de traslado sutil -->
                    <tr>
                        <td colspan="2" style="background: #555555; color: white; padding: 5px 6px; border: 1px solid #555;">
                            <div style="display: flex; align-items: center;">
                                <div style="flex: 1;"></div>
                                <strong style="flex: 0; font-size: 11pt; letter-spacing: 0.5px; text-align: center; white-space: nowrap;">FASE DE EXPEDICIÓN CONFORME</strong>
                                <div style="flex: 1; text-align: right; font-size: 6pt; color: #bbb; font-weight: normal; padding-left: 4px;">
                                    <t t-esc="o.name"/>
                                </div>
                            </div>
                        </td>
                    </tr>

                    <!-- ARTICULO | ORDEN con barcodes -->
                    <tr>
                        <!-- ARTICULO: default_code > barcode del producto -->
                        <td style="width: 50%; border: 1px solid #aaa; padding: 3px 4px; text-align: center; height: 28mm; vertical-align: top;">
                            <div style="font-size: 7pt; font-weight: bold; color: #555; margin-bottom: 2px;">ARTICULO</div>
                            <t t-if="linea_albaran.product_id">
                                <t t-set="cod_art" t-value="linea_albaran.product_id.default_code or linea_albaran.product_id.barcode"/>
                                <t t-if="cod_art">
                                    <img style="width: 90%; height: 16mm;"
                                         t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', cod_art, 200, 60)"/>
                                    <div style="font-size: 8pt;"><t t-esc="cod_art"/></div>
                                </t>
                            </t>
                        </td>
                        <!-- ORDEN: fabricacion > sale order -->
                        <td style="width: 50%; border: 1px solid #aaa; padding: 3px 4px; text-align: center; height: 28mm; vertical-align: top;">
                            <div style="font-size: 7pt; font-weight: bold; color: #555; margin-bottom: 2px;">ORDEN</div>
                            <t t-if="linea_albaran.fabricacion">
                                <img style="width: 90%; height: 16mm;"
                                     t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', linea_albaran.fabricacion.name, 200, 60)"/>
                                <div style="font-size: 8pt;"><t t-esc="linea_albaran.fabricacion.name"/></div>
                            </t>
                            <t t-elif="linea_albaran.sale_line_id">
                                <img style="width: 90%; height: 16mm;"
                                     t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', linea_albaran.sale_line_id.order_id.name, 200, 60)"/>
                                <div style="font-size: 8pt;"><t t-esc="linea_albaran.sale_line_id.order_id.name"/></div>
                            </t>
                        </td>
                    </tr>

                    <!-- DESCRIPCIÓN -->
                    <tr>
                        <td colspan="2" style="border: 1px solid #aaa; padding: 3px 5px; height: 16mm; vertical-align: top;">
                            <div style="font-size: 7pt; font-weight: bold; color: #555;">DESCRIPCIÓN</div>
                            <div style="font-size: 9pt; font-weight: bold; margin-top: 2px;">
                                <t t-if="linea_albaran.product_id">
                                    <t t-esc="linea_albaran.product_id.name"/>
                                </t>
                            </div>
                        </td>
                    </tr>

                    <!-- REF. CLIENTE -->
                    <tr>
                        <td colspan="2" style="border: 1px solid #aaa; padding: 3px 5px; height: 9mm; vertical-align: middle;">
                            <span style="font-size: 7pt; font-weight: bold; color: #555;">REF. CLIENTE </span>
                            <span style="font-size: 9pt;">
                                <t t-if="linea_albaran.product_id and linea_albaran.product_id.description_sale">
                                    <t t-esc="linea_albaran.product_id.description_sale"/>
                                </t>
                            </span>
                        </td>
                    </tr>

                    <!-- PEDIDO JR -->
                    <tr>
                        <td colspan="2" style="border: 1px solid #aaa; padding: 3px 5px; height: 9mm; vertical-align: middle;">
                            <span style="font-size: 7pt; font-weight: bold; color: #555;">PEDIDO JR </span>
                            <span style="font-size: 9pt;">
                                <t t-if="linea_albaran.sale_line_id">
                                    <t t-esc="linea_albaran.sale_line_id.order_id.name"/>
                                </t>
                            </span>
                        </td>
                    </tr>

                    <!-- Nº PEDIDO CLIENTE -->
                    <tr>
                        <td colspan="2" style="border: 1px solid #aaa; padding: 3px 5px; height: 9mm; vertical-align: middle;">
                            <span style="font-size: 7pt; font-weight: bold; color: #555;">Nº PEDIDO CLIENTE </span>
                            <span style="font-size: 9pt;">
                                <t t-if="linea_albaran.sale_line_id">
                                    <t t-esc="linea_albaran.sale_line_id.order_id.client_order_ref"/>
                                </t>
                            </span>
                        </td>
                    </tr>

                    <!-- CLIENTE -->
                    <tr>
                        <td colspan="2" style="border: 1px solid #aaa; padding: 3px 5px; height: 14mm; vertical-align: top;">
                            <div style="font-size: 7pt; font-weight: bold; color: #555;">CLIENTE
                                <t t-if="cliente_expedicion.ref">
                                    <span style="color: #333; font-weight: normal;">&#160;<t t-esc="cliente_expedicion.ref"/></span>
                                </t>
                            </div>
                            <div style="font-size: 10pt; font-weight: bold; margin-top: 2px;">
                                <t t-esc="cliente_expedicion.name"/>
                            </div>
                        </td>
                    </tr>

                    <!-- CANTIDAD -->
                    <tr>
                        <td colspan="2" style="border: 1px solid #aaa; padding: 3px 5px; height: 20mm; vertical-align: top;">
                            <div style="font-size: 7pt; font-weight: bold; color: #555;">CANTIDAD</div>
                        </td>
                    </tr>

                    <!-- LOGO -->
                    <tr>
                        <td colspan="2" style="text-align: center; padding: 3px; height: 12mm; vertical-align: middle;">
                            <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" alt="Logo" style="height: 10mm;"/>
                        </td>
                    </tr>

                </table>
            </div>
        </t>
    </template>

    <!-- ── RECEPCIÓN ──────────────────────────────────────────────────────── -->
    <template id="etiqueta_albaran_recepcion_document">
        <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>
        <t t-foreach="o.move_ids_without_package" t-as="linea_albaran">

            <!-- Resolver cliente: fabricacion > sale_line > partner directo del picking -->
            <t t-set="cliente_recepcion" t-value="(linea_albaran.fabricacion.partner_id) or (linea_albaran.sale_line_id.order_id.partner_id) or o.partner_id"/>

            <div class="page article" style="font-family: Arial, sans-serif; box-sizing: border-box; padding: 3mm;">
                <table style="width: 100%; border-collapse: collapse; table-layout: fixed;">

                    <!-- CABECERA + número de traslado sutil -->
                    <tr>
                        <td colspan="2" style="background: #555555; color: white; padding: 5px 6px; border: 1px solid #555;">
                            <div style="display: flex; align-items: center;">
                                <div style="flex: 1;"></div>
                                <strong style="flex: 0; font-size: 11pt; letter-spacing: 0.5px; text-align: center; white-space: nowrap;">FASE DE RECEPCIÓN CONFORME</strong>
                                <div style="flex: 1; text-align: right; font-size: 6pt; color: #bbb; font-weight: normal; padding-left: 4px;">
                                    <t t-esc="o.name"/>
                                </div>
                            </div>
                        </td>
                    </tr>

                    <!-- ORDEN | ARTICULO con barcodes -->
                    <tr>
                        <td style="width: 50%; border: 1px solid #aaa; padding: 3px 4px; text-align: center; height: 28mm; vertical-align: top;">
                            <div style="font-size: 7pt; font-weight: bold; color: #555; margin-bottom: 2px;">ORDEN</div>
                            <t t-if="linea_albaran.fabricacion">
                                <img style="width: 90%; height: 16mm;"
                                     t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', linea_albaran.fabricacion.name, 200, 60)"/>
                                <div style="font-size: 8pt;"><t t-esc="linea_albaran.fabricacion.name"/></div>
                            </t>
                            <t t-elif="linea_albaran.purchase_line_id">
                                <img style="width: 90%; height: 16mm;"
                                     t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', linea_albaran.purchase_line_id.order_id.name, 200, 60)"/>
                                <div style="font-size: 8pt;"><t t-esc="linea_albaran.purchase_line_id.order_id.name"/></div>
                            </t>
                        </td>
                        <!-- ARTICULO: default_code > barcode del producto -->
                        <td style="width: 50%; border: 1px solid #aaa; padding: 3px 4px; text-align: center; height: 28mm; vertical-align: top;">
                            <div style="font-size: 7pt; font-weight: bold; color: #555; margin-bottom: 2px;">ARTICULO</div>
                            <t t-if="linea_albaran.product_id">
                                <t t-set="cod_art" t-value="linea_albaran.product_id.default_code or linea_albaran.product_id.barcode"/>
                                <t t-if="cod_art">
                                    <img style="width: 90%; height: 16mm;"
                                         t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', cod_art, 200, 60)"/>
                                    <div style="font-size: 8pt;"><t t-esc="cod_art"/></div>
                                </t>
                            </t>
                        </td>
                    </tr>

                    <!-- DESCRIPCION -->
                    <tr>
                        <td colspan="2" style="border: 1px solid #aaa; padding: 3px 5px; height: 16mm; vertical-align: top;">
                            <div style="font-size: 7pt; font-weight: bold; color: #555;">DESCRIPCION</div>
                            <div style="font-size: 9pt; font-weight: bold; margin-top: 2px;">
                                <t t-if="linea_albaran.product_id">
                                    <t t-esc="linea_albaran.product_id.name"/>
                                </t>
                            </div>
                        </td>
                    </tr>

                    <!-- FECHA VENCIMIENTO -->
                    <tr>
                        <td colspan="2" style="border: 1px solid #aaa; padding: 3px 5px; height: 9mm; vertical-align: middle;">
                            <span style="font-size: 7pt; font-weight: bold; color: #555;">FECHA VENCIMIENTO </span>
                            <span style="font-size: 9pt;">
                                <t t-if="o.scheduled_date">
                                    <t t-esc="o.scheduled_date.strftime('%d/%m/%Y')"/>
                                </t>
                            </span>
                        </td>
                    </tr>

                    <!-- PEDIDO -->
                    <tr>
                        <td colspan="2" style="border: 1px solid #aaa; padding: 3px 5px; height: 9mm; vertical-align: middle;">
                            <span style="font-size: 7pt; font-weight: bold; color: #555;">PEDIDO </span>
                            <span style="font-size: 9pt;">
                                <t t-if="linea_albaran.purchase_line_id">
                                    <t t-esc="linea_albaran.purchase_line_id.order_id.name"/>
                                </t>
                            </span>
                        </td>
                    </tr>

                    <!-- REF. PEDIDO -->
                    <tr>
                        <td colspan="2" style="border: 1px solid #aaa; padding: 3px 5px; height: 9mm; vertical-align: middle;">
                            <span style="font-size: 7pt; font-weight: bold; color: #555;">REF. PEDIDO </span>
                            <span style="font-size: 9pt;">
                                <t t-if="linea_albaran.purchase_line_id">
                                    <t t-esc="linea_albaran.purchase_line_id.order_id.partner_ref"/>
                                </t>
                            </span>
                        </td>
                    </tr>

                    <!-- CLIENTE -->
                    <tr>
                        <td colspan="2" style="border: 1px solid #aaa; padding: 3px 5px; height: 14mm; vertical-align: top;">
                            <div style="font-size: 7pt; font-weight: bold; color: #555;">CLIENTE
                                <t t-if="cliente_recepcion.ref">
                                    <span style="color: #333; font-weight: normal;">&#160;<t t-esc="cliente_recepcion.ref"/></span>
                                </t>
                            </div>
                            <div style="font-size: 10pt; font-weight: bold; margin-top: 2px;">
                                <t t-esc="cliente_recepcion.name"/>
                            </div>
                        </td>
                    </tr>

                    <!-- CANTIDAD | LONGITUD -->
                    <tr>
                        <td style="width: 50%; border: 1px solid #aaa; padding: 3px 5px; height: 20mm; vertical-align: top;">
                            <div style="font-size: 7pt; font-weight: bold; color: #555;">CANTIDAD</div>
                        </td>
                        <td style="width: 50%; border: 1px solid #aaa; padding: 3px 5px; height: 20mm; vertical-align: top;">
                            <div style="font-size: 7pt; font-weight: bold; color: #555;">LONGITUD:</div>
                        </td>
                    </tr>

                    <!-- LOGO -->
                    <tr>
                        <td colspan="2" style="text-align: center; padding: 3px; height: 12mm; vertical-align: middle;">
                            <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" alt="Logo" style="height: 10mm;"/>
                        </td>
                    </tr>

                </table>
            </div>
        </t>
    </template>

</odoo>
