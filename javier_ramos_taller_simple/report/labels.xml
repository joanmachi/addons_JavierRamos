<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="etiqueta_albaran">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-if="o.picking_type_id.barcode == 'WHOUT'">
                    <t t-call="javier_ramos_taller_simple.etiqueta_albaran_entrega_document" t-lang="o.partner_id.lang"/>
                </t>
                <t t-if="o.picking_type_id.barcode == 'WHIN'">
                    <t t-call="javier_ramos_taller_simple.etiqueta_albaran_recepcion_document" t-lang="o.partner_id.lang"/>
                </t>
            </t>
        </t>
    </template>

    <!-- ── EXPEDICIÓN ─────────────────────────────────────────────────────── -->
    <template id="etiqueta_albaran_entrega_document">
        <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>
        <t t-foreach="o.move_ids_without_package" t-as="linea_albaran">
            <t t-set="cliente_expedicion" t-value="linea_albaran.sale_line_id.order_id.partner_id or o.partner_id"/>

            <div class="page article" style="font-family: Arial, sans-serif; box-sizing: border-box; padding: 3mm;">
                <style>
                    table, tr, td, th { border: none !important; border-width: 0 !important; }
                </style>

                <!-- LOGO sin borde -->
                <div style="text-align: center; padding: 2mm 0 2mm 0;">
                    <img t-if="o.company_id.logo_web" t-att-src="image_data_uri(o.company_id.logo_web)" alt="Logo" style="height: 20mm;"/>
                </div>

                <!-- BLOQUE CON BORDE EXTERIOR -->
                <div style="border: 1px solid #888;">

                    <!-- CABECERA gris -->
                    <div style="background: #555555; color: white; padding: 5px 6px; position: relative;">
                        <strong style="display: block; text-align: center; font-size: 13pt; letter-spacing: 0.5px; white-space: nowrap;">FASE DE EXPEDICIÓN CONFORME</strong>
                        <span style="position: absolute; top: 6px; right: 6px; font-size: 7pt; color: #bbb;"><t t-esc="o.name"/></span>
                    </div>

                    <!-- ARTICULO | ORDEN barcodes con separador vertical -->
                    <table style="width: 100%; border-collapse: collapse; table-layout: fixed;">
                        <tr>
                            <td style="width: 49%; text-align: center; height: 30mm; vertical-align: top; padding: 3px 4px;">
                                <div style="font-size: 8pt; font-weight: bold; color: #555; margin-bottom: 2px;">ARTICULO</div>
                                <t t-if="linea_albaran.product_id">
                                    <t t-set="cod_art" t-value="linea_albaran.product_id.default_code or linea_albaran.product_id.barcode"/>
                                    <t t-if="cod_art">
                                        <img style="width: 90%; height: 17mm;"
                                             t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', cod_art, 200, 60)"/>
                                        <div style="font-size: 9pt; font-weight: bold;"><t t-esc="cod_art"/></div>
                                    </t>
                                </t>
                            </td>
                            <td style="width: 2%; padding: 0;" bgcolor="#cccccc">&#160;</td>
                            <td style="width: 49%; text-align: center; height: 30mm; vertical-align: top; padding: 3px 4px;">
                                <div style="font-size: 8pt; font-weight: bold; color: #555; margin-bottom: 2px;">ORDEN</div>
                                <t t-if="linea_albaran.fabricacion">
                                    <img style="width: 90%; height: 17mm;"
                                         t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', linea_albaran.fabricacion.name, 200, 60)"/>
                                    <div style="font-size: 9pt; font-weight: bold;"><t t-esc="linea_albaran.fabricacion.name"/></div>
                                </t>
                                <t t-elif="linea_albaran.sale_line_id">
                                    <img style="width: 90%; height: 17mm;"
                                         t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', linea_albaran.sale_line_id.order_id.name, 200, 60)"/>
                                    <div style="font-size: 9pt; font-weight: bold;"><t t-esc="linea_albaran.sale_line_id.order_id.name"/></div>
                                </t>
                            </td>
                        </tr>
                    </table>

                    <!-- DESCRIPCIÓN -->
                    <div style="padding: 3px 5px; min-height: 14mm;">
                        <div style="font-size: 8pt; font-weight: bold; color: #555;">DESCRIPCIÓN</div>
                        <div style="font-size: 11pt; font-weight: bold; margin-top: 2px;">
                            <t t-if="linea_albaran.product_id"><t t-esc="linea_albaran.product_id.name"/></t>
                        </div>
                    </div>

                    <!-- REF. CLIENTE -->
                    <div style="padding: 3px 5px; min-height: 9mm;">
                        <div style="font-size: 8pt; font-weight: bold; color: #555;">REF. CLIENTE</div>
                        <div style="font-size: 11pt; font-weight: bold;">
                            <!-- Referencia del cliente PARA EL PRODUCTO: campo
                                 "Descripción del presupuesto" de la ficha (description_sale) -->
                            <t t-esc="(linea_albaran.product_id.description_sale or '').strip()"/>
                        </div>
                    </div>

                    <!-- PEDIDO JR -->
                    <div style="padding: 3px 5px; min-height: 9mm;">
                        <div style="font-size: 8pt; font-weight: bold; color: #555;">PEDIDO JR</div>
                        <div style="font-size: 11pt; font-weight: bold;">
                            <t t-if="linea_albaran.sale_line_id"><t t-esc="linea_albaran.sale_line_id.order_id.name"/></t>
                        </div>
                    </div>

                    <!-- Nº PEDIDO CLIENTE -->
                    <div style="padding: 3px 5px; min-height: 9mm;">
                        <div style="font-size: 8pt; font-weight: bold; color: #555;">Nº PEDIDO CLIENTE</div>
                        <div style="font-size: 11pt; font-weight: bold;">
                            <t t-if="linea_albaran.sale_line_id"><t t-esc="linea_albaran.sale_line_id.order_id.client_order_ref"/></t>
                        </div>
                    </div>

                    <!-- CLIENTE -->
                    <div style="padding: 3px 5px; min-height: 12mm;">
                        <div style="font-size: 8pt; font-weight: bold; color: #555;">CLIENTE
                            <t t-if="cliente_expedicion.ref">
                                <span style="font-weight: bold; color: #333;">&#160;<t t-esc="cliente_expedicion.ref"/></span>
                            </t>
                        </div>
                        <div style="font-size: 12pt; font-weight: bold; margin-top: 2px;"><t t-esc="cliente_expedicion.name"/></div>
                    </div>

                    <!-- CANTIDAD | LONGITUD con separador vertical -->
                    <table style="width: 100%; border-collapse: collapse; table-layout: fixed;">
                        <tr>
                            <td style="width: 49%; padding: 3px 5px; height: 16mm; vertical-align: top;">
                                <div style="font-size: 8pt; font-weight: bold; color: #555;">CANTIDAD</div>
                            </td>
                            <td style="width: 2%; padding: 0;" bgcolor="#cccccc">&#160;</td>
                            <td style="width: 49%; padding: 3px 5px; height: 16mm; vertical-align: top;">
                                <div style="font-size: 8pt; font-weight: bold; color: #555;">LONGITUD:</div>
                            </td>
                        </tr>
                    </table>

                </div>
            </div>
        </t>
    </template>

    <!-- ── RECEPCIÓN ──────────────────────────────────────────────────────── -->
    <template id="etiqueta_albaran_recepcion_document">
        <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>
        <t t-foreach="o.move_ids_without_package" t-as="linea_albaran">
            <t t-set="cliente_recepcion" t-value="(linea_albaran.fabricacion.partner_id) or (linea_albaran.sale_line_id.order_id.partner_id) or o.partner_id"/>

            <div class="page article" style="font-family: Arial, sans-serif; box-sizing: border-box; padding: 3mm;">
                <style>
                    table, tr, td, th { border: none !important; border-width: 0 !important; }
                </style>

                <!-- LOGO sin borde -->
                <div style="text-align: center; padding: 2mm 0 2mm 0;">
                    <img t-if="o.company_id.logo_web" t-att-src="image_data_uri(o.company_id.logo_web)" alt="Logo" style="height: 20mm;"/>
                </div>

                <!-- BLOQUE CON BORDE EXTERIOR -->
                <div style="border: 1px solid #888;">

                    <!-- CABECERA gris -->
                    <div style="background: #555555; color: white; padding: 5px 6px; position: relative;">
                        <strong style="display: block; text-align: center; font-size: 13pt; letter-spacing: 0.5px; white-space: nowrap;">FASE DE RECEPCIÓN CONFORME</strong>
                        <span style="position: absolute; top: 6px; right: 6px; font-size: 7pt; color: #bbb;"><t t-esc="o.name"/></span>
                    </div>

                    <!-- ORDEN | ARTICULO barcodes con separador vertical -->
                    <table style="width: 100%; border-collapse: collapse; table-layout: fixed;">
                        <tr>
                            <td style="width: 49%; text-align: center; height: 30mm; vertical-align: top; padding: 3px 4px;">
                                <div style="font-size: 8pt; font-weight: bold; color: #555; margin-bottom: 2px;">ORDEN</div>
                                <t t-if="linea_albaran.fabricacion">
                                    <img style="width: 90%; height: 17mm;"
                                         t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', linea_albaran.fabricacion.name, 200, 60)"/>
                                    <div style="font-size: 9pt; font-weight: bold;"><t t-esc="linea_albaran.fabricacion.name"/></div>
                                </t>
                                <t t-elif="linea_albaran.purchase_line_id">
                                    <img style="width: 90%; height: 17mm;"
                                         t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', linea_albaran.purchase_line_id.order_id.name, 200, 60)"/>
                                    <div style="font-size: 9pt; font-weight: bold;"><t t-esc="linea_albaran.purchase_line_id.order_id.name"/></div>
                                </t>
                            </td>
                            <td style="width: 2%; padding: 0;" bgcolor="#cccccc">&#160;</td>
                            <td style="width: 49%; text-align: center; height: 30mm; vertical-align: top; padding: 3px 4px;">
                                <div style="font-size: 8pt; font-weight: bold; color: #555; margin-bottom: 2px;">ARTICULO</div>
                                <t t-if="linea_albaran.product_id">
                                    <t t-set="cod_art" t-value="linea_albaran.product_id.default_code or linea_albaran.product_id.barcode"/>
                                    <t t-if="cod_art">
                                        <img style="width: 90%; height: 17mm;"
                                             t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', cod_art, 200, 60)"/>
                                        <div style="font-size: 9pt; font-weight: bold;"><t t-esc="cod_art"/></div>
                                    </t>
                                </t>
                            </td>
                        </tr>
                    </table>

                    <!-- DESCRIPCION -->
                    <div style="padding: 3px 5px; min-height: 14mm;">
                        <div style="font-size: 8pt; font-weight: bold; color: #555;">DESCRIPCION</div>
                        <div style="font-size: 11pt; font-weight: bold; margin-top: 2px;">
                            <t t-if="linea_albaran.product_id"><t t-esc="linea_albaran.product_id.name"/></t>
                        </div>
                    </div>

                    <!-- FECHA VENCIMIENTO -->
                    <div style="padding: 3px 5px; min-height: 9mm;">
                        <div style="font-size: 8pt; font-weight: bold; color: #555;">FECHA VENCIMIENTO</div>
                        <div style="font-size: 11pt; font-weight: bold;">
                            <t t-if="o.scheduled_date"><t t-esc="o.scheduled_date.strftime('%d/%m/%Y')"/></t>
                        </div>
                    </div>

                    <!-- PEDIDO -->
                    <div style="padding: 3px 5px; min-height: 9mm;">
                        <div style="font-size: 8pt; font-weight: bold; color: #555;">PEDIDO</div>
                        <div style="font-size: 11pt; font-weight: bold;">
                            <t t-if="linea_albaran.purchase_line_id"><t t-esc="linea_albaran.purchase_line_id.order_id.name"/></t>
                        </div>
                    </div>

                    <!-- REF. PEDIDO -->
                    <div style="padding: 3px 5px; min-height: 9mm;">
                        <div style="font-size: 8pt; font-weight: bold; color: #555;">REF. PEDIDO</div>
                        <div style="font-size: 11pt; font-weight: bold;">
                            <t t-if="linea_albaran.purchase_line_id"><t t-esc="linea_albaran.purchase_line_id.order_id.partner_ref"/></t>
                        </div>
                    </div>

                    <!-- CLIENTE -->
                    <div style="padding: 3px 5px; min-height: 12mm;">
                        <div style="font-size: 8pt; font-weight: bold; color: #555;">CLIENTE
                            <t t-if="cliente_recepcion.ref">
                                <span style="font-weight: bold; color: #333;">&#160;<t t-esc="cliente_recepcion.ref"/></span>
                            </t>
                        </div>
                        <div style="font-size: 12pt; font-weight: bold; margin-top: 2px;"><t t-esc="cliente_recepcion.name"/></div>
                    </div>

                    <!-- CANTIDAD | LONGITUD con separador vertical -->
                    <table style="width: 100%; border-collapse: collapse; table-layout: fixed;">
                        <tr>
                            <td style="width: 49%; padding: 3px 5px; height: 16mm; vertical-align: top;">
                                <div style="font-size: 8pt; font-weight: bold; color: #555;">CANTIDAD</div>
                            </td>
                            <td style="width: 2%; padding: 0;" bgcolor="#cccccc">&#160;</td>
                            <td style="width: 49%; padding: 3px 5px; height: 16mm; vertical-align: top;">
                                <div style="font-size: 8pt; font-weight: bold; color: #555;">LONGITUD:</div>
                            </td>
                        </tr>
                    </table>

                </div>
            </div>
        </t>
    </template>

</odoo>
