<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- 1. Smart button "Costes OF" en form view nativa de mrp.production -->
    <!-- ============================================================ -->
    <record id="view_apunts_mrp_production_form_smart_button" model="ir.ui.view">
        <field name="name">mrp.production.form.inherit.apunts.costes.smart.button</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_apunts_open_costes"
                        type="object"
                        class="oe_stat_button apunts_costes_smart_button"
                        icon="fa-eur">
                    <div class="o_stat_info">
                        <span class="o_stat_text apunts_costes_label_only">COSTE OF</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- HITO 10: vista list editable de mrp.workcenter.productivity -->
    <!-- (Editor horas admin filtrado por OF)                         -->
    <!-- ============================================================ -->
    <record id="view_apunts_productivity_editor_list" model="ir.ui.view">
        <field name="name">apunts.productivity.editor.list</field>
        <field name="model">mrp.workcenter.productivity</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <!-- v18.0.9.0.0: modulo SOLO CONSULTA - lista solo lectura (no editable) -->
            <list string="Editor horas (consulta)" multi_edit="0"
                  create="false" delete="false" edit="false"
                  decoration-warning="not employee_id"
                  decoration-muted="not date_end">
                <field name="workorder_id" string="OT" readonly="1"/>
                <field name="workcenter_id" string="Centro" readonly="1"/>
                <field name="employee_id" string="Empleado" readonly="1"/>
                <field name="date_start" string="Inicio" readonly="1"/>
                <field name="date_end" string="Fin" readonly="1"/>
                <field name="duration" string="Duracion (min)" readonly="1"/>
                <field name="loss_id" string="Motivo paro" optional="hide" readonly="1"/>
                <field name="description" string="Descripcion" optional="hide" readonly="1"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- 2. Vista form ALTERNATIVA "Costes OF" (priority alta para no ser default) -->
    <!-- ============================================================ -->
    <record id="view_apunts_mrp_production_form_costes" model="ir.ui.view">
        <field name="name">apunts.mrp.production.form.costes</field>
        <field name="model">mrp.production</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <form string="Costes OF" create="false" delete="false" edit="false"
                  class="apunts_costes_form">
                <header>
                    <button name="action_apunts_back_to_main" type="object"
                            string="&#8592; Volver a OF" class="btn-secondary"/>
                    <button name="action_apunts_refresh_costes" type="object"
                            string="&#x21BB; Refrescar" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title apunts_compact_title">
                        <h2 class="mb-1">
                            <field name="name" readonly="1" class="oe_inline"/>
                            <span class="text-muted ms-2"> &#8226; </span>
                            <field name="product_id" readonly="1" class="oe_inline"/>
                            <span class="text-muted ms-1"> &#8226; </span>
                            <field name="product_qty" readonly="1" class="oe_inline"/>
                            <span class="text-muted ms-1"> &#8226; </span>
                            <field name="state" readonly="1" widget="badge" class="oe_inline"
                                   decoration-success="state == 'done'"
                                   decoration-info="state == 'progress'"
                                   decoration-muted="state in ('confirmed', 'draft')"/>
                        </h2>
                    </div>

                    <!-- ============================================ -->
                    <!-- KPI cards: 2 cards (Coste actual + Coste    -->
                    <!-- total estimado). Desglose via botón wizard.  -->
                    <!-- ============================================ -->
                    <div class="apunts_kpi_row apunts_kpi_row_2col" name="apunts_kpi_cards">

                        <!-- Card: Coste actual (real consumido) -->
                        <div class="apunts_kpi_card apunts_kpi_actual">
                            <div class="apunts_kpi_button" style="padding: 14px 16px;">
                                <div class="apunts_kpi_label">
                                    COSTE ACTUAL
                                    <i class="fa fa-info-circle apunts_info_icon"
                                       title="Coste real acumulado hasta hoy: material ya consumido + mano de obra imputada + coste de centros. Solo incluye lo que ha pasado por la OF. Para ver el desglose completo, usa el botón Desglose detallado."/>
                                </div>
                                <div class="apunts_kpi_top">
                                    <field name="apunts_total_cost_real" widget="monetary"
                                           class="apunts_kpi_top_value apunts_kpi_top_real"/>
                                </div>
                                <div class="apunts_kpi_breakdown">
                                    <span class="apunts_kpi_breakdown_item">
                                        <span class="apunts_kpi_breakdown_label">Material:</span>
                                        <field name="apunts_material_cost_real" widget="monetary" class="oe_inline"/>
                                    </span>
                                    <span class="apunts_kpi_breakdown_item">
                                        <span class="apunts_kpi_breakdown_label">M. Obra:</span>
                                        <field name="apunts_labor_cost_real" widget="monetary" class="oe_inline"/>
                                    </span>
                                    <span class="apunts_kpi_breakdown_item">
                                        <span class="apunts_kpi_breakdown_label">Centros:</span>
                                        <field name="apunts_operation_cost_real" widget="monetary" class="oe_inline"/>
                                    </span>
                                </div>
                                <div class="mt-2">
                                    <button name="action_apunts_open_desglose"
                                            type="object"
                                            string="Ver desglose"
                                            class="btn btn-link btn-sm p-0"
                                            icon="fa-search-plus"
                                            help="Abre desglose detallado: componentes consumidos, cantidades, precios, proveedor / pedido de compra asociado, mano de obra y centros."/>
                                </div>
                            </div>
                        </div>

                        <!-- Card: Coste total estimado (planificado) -->
                        <div class="apunts_kpi_card apunts_kpi_estimado">
                            <div class="apunts_kpi_button" style="padding: 14px 16px;">
                                <div class="apunts_kpi_label">
                                    COSTE TEORICO
                                    <i class="fa fa-info-circle apunts_info_icon"
                                       title="Coste teorico segun BoM y routing: materia prima presupuestada (precio estandar x cantidad necesaria) + mano de obra estimada (horas planificadas x tarifa empleado) + coste de centros (horas planificadas x tarifa centro). Es lo que DEBERIA costar fabricar la OF. Compara con 'Coste actual' para ver la desviacion."/>
                                </div>
                                <div class="apunts_kpi_top">
                                    <field name="apunts_total_cost_planned" widget="monetary"
                                           class="apunts_kpi_top_value apunts_kpi_top_plan"/>
                                </div>
                                <div class="apunts_kpi_breakdown">
                                    <span class="apunts_kpi_breakdown_item">
                                        <span class="apunts_kpi_breakdown_label">Material:</span>
                                        <field name="apunts_material_cost_planned" widget="monetary" class="oe_inline"/>
                                    </span>
                                    <span class="apunts_kpi_breakdown_item">
                                        <span class="apunts_kpi_breakdown_label">M. Obra:</span>
                                        <field name="apunts_labor_cost_planned" widget="monetary" class="oe_inline"/>
                                    </span>
                                    <span class="apunts_kpi_breakdown_item">
                                        <span class="apunts_kpi_breakdown_label">Centros:</span>
                                        <field name="apunts_operation_cost_planned" widget="monetary" class="oe_inline"/>
                                    </span>
                                </div>
                                <div class="apunts_kpi_dev">
                                    <field name="apunts_total_dev_display" readonly="1" nolabel="1"/>
                                </div>
                                <div class="mt-2">
                                    <button name="action_apunts_open_desglose"
                                            type="object"
                                            string="Ver desglose"
                                            class="btn btn-link btn-sm p-0"
                                            icon="fa-search-plus"
                                            help="Abre desglose detallado: BoM con componentes presupuestados, cantidades necesarias, precios estandar, mano de obra y centros estimados."/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ============================================ -->
                    <!-- Hito 4 + 8: bloque destacado MARGEN COMERCIAL -->
                    <!-- Color condicionado por apunts_margin_state    -->
                    <!-- ============================================ -->
                    <field name="apunts_margin_state" invisible="1"/>
                    <field name="apunts_margin_explanation" invisible="1"/>
                    <div class="apunts_margin_block apunts_margin_green"
                         invisible="apunts_margin_state != 'green'">
                        <div class="apunts_margin_grid">
                            <div class="apunts_margin_cell">
                                <div class="apunts_margin_cell_label">
                                    Ingreso total
                                    <i class="fa fa-info-circle apunts_info_icon"
                                       title="Suma del importe (price_subtotal) de las lineas del sale.order vinculado a esta OF (sea por origin = SO, por sale_line_id, o por campo Studio personalizado). Es lo que se factura al cliente por la pieza fabricada."/>
                                </div>
                                <div class="apunts_margin_cell_value text-success">
                                    <field name="apunts_revenue_total" widget="monetary" nolabel="1" readonly="1"/>
                                </div>
                            </div>
                            <div class="apunts_margin_cell">
                                <div class="apunts_margin_cell_label">
                                    Coste real total
                                    <i class="fa fa-info-circle apunts_info_icon"
                                       title="Material consumido + mano de obra imputada + coste de centros de trabajo. Mismo valor que la card 'COSTE ACTUAL' de arriba."/>
                                </div>
                                <div class="apunts_margin_cell_value">
                                    <field name="apunts_total_cost_real" widget="monetary" nolabel="1" readonly="1"/>
                                </div>
                            </div>
                            <div class="apunts_margin_cell">
                                <div class="apunts_margin_cell_label">
                                    Margen €
                                    <i class="fa fa-info-circle apunts_info_icon"
                                       title="Calculo: Ingreso total - Coste real total. Es el dinero que dejamos (positivo) o perdemos (negativo) al fabricar esta OF."/>
                                </div>
                                <div class="apunts_margin_cell_value text-success">
                                    <field name="apunts_margin_total" widget="monetary" nolabel="1" readonly="1"/>
                                </div>
                            </div>
                            <div class="apunts_margin_cell">
                                <div class="apunts_margin_cell_label">
                                    Margen %
                                    <i class="fa fa-info-circle apunts_info_icon"
                                       title="Calculo: (Margen / Ingreso total) x 100. Verde = margen mayor o igual a 20%; Ambar = entre 0% y 20%; Rojo = perdiendo dinero."/>
                                </div>
                                <div class="apunts_margin_cell_value text-success">
                                    <field name="apunts_margin_pct" nolabel="1" readonly="1"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="apunts_margin_block apunts_margin_amber"
                         invisible="apunts_margin_state != 'amber'">
                        <div class="apunts_margin_grid">
                            <div class="apunts_margin_cell">
                                <div class="apunts_margin_cell_label">
                                    Ingreso total
                                    <i class="fa fa-info-circle apunts_info_icon"
                                       title="Suma del importe (price_subtotal) de las lineas del sale.order vinculado a esta OF."/>
                                </div>
                                <div class="apunts_margin_cell_value">
                                    <field name="apunts_revenue_total" widget="monetary" nolabel="1" readonly="1"/>
                                </div>
                            </div>
                            <div class="apunts_margin_cell">
                                <div class="apunts_margin_cell_label">
                                    Coste real total
                                    <i class="fa fa-info-circle apunts_info_icon"
                                       title="Material consumido + mano de obra imputada + coste de centros."/>
                                </div>
                                <div class="apunts_margin_cell_value">
                                    <field name="apunts_total_cost_real" widget="monetary" nolabel="1" readonly="1"/>
                                </div>
                            </div>
                            <div class="apunts_margin_cell">
                                <div class="apunts_margin_cell_label">
                                    Margen €
                                    <i class="fa fa-info-circle apunts_info_icon"
                                       title="Calculo: Ingreso total - Coste real total."/>
                                </div>
                                <div class="apunts_margin_cell_value text-warning">
                                    <field name="apunts_margin_total" widget="monetary" nolabel="1" readonly="1"/>
                                </div>
                            </div>
                            <div class="apunts_margin_cell">
                                <div class="apunts_margin_cell_label">
                                    Margen %
                                    <i class="fa fa-info-circle apunts_info_icon"
                                       title="(Margen / Ingreso total) x 100. Ambar = entre 0% y 20%."/>
                                </div>
                                <div class="apunts_margin_cell_value text-warning">
                                    <field name="apunts_margin_pct" nolabel="1" readonly="1"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="apunts_margin_block apunts_margin_red"
                         invisible="apunts_margin_state != 'red'">
                        <div class="apunts_margin_grid">
                            <div class="apunts_margin_cell">
                                <div class="apunts_margin_cell_label">
                                    Ingreso total
                                    <i class="fa fa-info-circle apunts_info_icon"
                                       title="Suma del importe (price_subtotal) de las lineas del sale.order vinculado a esta OF."/>
                                </div>
                                <div class="apunts_margin_cell_value">
                                    <field name="apunts_revenue_total" widget="monetary" nolabel="1" readonly="1"/>
                                </div>
                            </div>
                            <div class="apunts_margin_cell">
                                <div class="apunts_margin_cell_label">
                                    Coste real total
                                    <i class="fa fa-info-circle apunts_info_icon"
                                       title="Material consumido + mano de obra imputada + coste de centros."/>
                                </div>
                                <div class="apunts_margin_cell_value text-danger">
                                    <field name="apunts_total_cost_real" widget="monetary" nolabel="1" readonly="1"/>
                                </div>
                            </div>
                            <div class="apunts_margin_cell">
                                <div class="apunts_margin_cell_label">
                                    Margen €
                                    <i class="fa fa-info-circle apunts_info_icon"
                                       title="Calculo: Ingreso total - Coste real total. Negativo = perdemos dinero al fabricar."/>
                                </div>
                                <div class="apunts_margin_cell_value text-danger">
                                    <field name="apunts_margin_total" widget="monetary" nolabel="1" readonly="1"/>
                                </div>
                            </div>
                            <div class="apunts_margin_cell">
                                <div class="apunts_margin_cell_label">
                                    Margen %
                                    <i class="fa fa-info-circle apunts_info_icon"
                                       title="(Margen / Ingreso total) x 100. Rojo = perdiendo dinero."/>
                                </div>
                                <div class="apunts_margin_cell_value text-danger">
                                    <field name="apunts_margin_pct" nolabel="1" readonly="1"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <notebook>
                        <!-- Seccion 1: Material -->
                        <page string="Material" name="apunts_material">
                            <div class="apunts_section_help">
                                <p>
                                    <i class="fa fa-info-circle me-1"/>
                                    Una fila por componente. <strong>Coste (€)</strong> = coste esperado total del componente (precio estandar x cantidad necesaria). <strong>Coste consumido</strong> = solo lo ya gastado. <strong>Falta sin PO</strong> = unidades sin cubrir.
                                </p>
                            </div>
                            <field name="apunts_material_line_ids" nolabel="1"
                                   context="{'tree_view_ref': 'apunts_costes_of.view_apunts_material_line_tree'}"/>
                        </page>

                        <!-- Seccion 2: Mano de obra y operaciones -->
                        <page string="Mano de obra y operaciones" name="apunts_labor">
                            <div class="apunts_section_help">
                                <p>
                                    <i class="fa fa-info-circle me-1"/>
                                    Una fila por orden de trabajo (OT). <strong>Coste (€)</strong> = horas imputadas x tarifa horaria empleado + tarifa centro de trabajo. <strong>% avance</strong> = horas reales / horas planificadas.
                                </p>
                            </div>
                            <field name="apunts_labor_line_ids" nolabel="1"
                                   context="{'tree_view_ref': 'apunts_costes_of.view_apunts_labor_line_tree'}"/>
                        </page>

                        <!-- Seccion 2-bis: Asistencias por empleado x dia (Hito 3) -->
                        <page string="Asistencias (empleado x dia)" name="apunts_attendance">
                            <div class="apunts_section_help">
                                <p>
                                    <i class="fa fa-info-circle me-1"/>
                                    Desglose de imputaciones por empleado y dia. Una fila por (empleado x dia x OT). <strong>Coste empleado</strong> = horas x hourly_cost. Ambar = empleado sin coste/hora configurado en master data.
                                </p>
                                <button name="action_apunts_drill_attendance" type="object"
                                        string="Ver pivot productivity entries (filtrable)"
                                        class="btn-link"/>
                            </div>
                            <field name="apunts_attendance_line_ids" nolabel="1"
                                   context="{'tree_view_ref': 'apunts_costes_of.view_apunts_attendance_line_tree'}"/>
                        </page>

                        <!-- Seccion 6: Producto terminado y trazabilidad forward (Hito 4) -->
                        <page string="Producto terminado (forward)" name="apunts_finished">
                            <div class="apunts_section_help">
                                <p>
                                    <i class="fa fa-info-circle me-1"/>
                                    Trazabilidad forward del producto terminado: lote producido, albaran de salida al cliente, pedido cliente vinculado y margen comercial. Si la OF no tiene SO vinculada (produccion a stock) los campos comerciales aparecen vacios y el margen no se calcula.
                                </p>
                                <button name="action_apunts_drill_finished" type="object"
                                        string="Ver moves de producto terminado"
                                        class="btn-link"/>
                                <button name="action_apunts_drill_sale" type="object"
                                        string="Abrir pedido cliente vinculado"
                                        class="btn-link"
                                        invisible="not apunts_revenue_total"/>
                            </div>
                            <field name="apunts_finished_line_ids" nolabel="1"
                                   context="{'tree_view_ref': 'apunts_costes_of.view_apunts_finished_line_tree'}"/>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <!-- ============================================================ -->
    <!-- Vista wizard desglose detallado de costes (modal)            -->
    <!-- ============================================================ -->
    <record id="view_apunts_desglose_wizard_form" model="ir.ui.view">
        <field name="name">apunts.costes.of.desglose.wizard.form</field>
        <field name="model">apunts.costes.of.desglose.wizard</field>
        <field name="arch" type="xml">
            <form string="Desglose costes OF" create="false" delete="false" edit="false">
                <sheet>
                    <div class="oe_title">
                        <h3 class="mb-2">
                            <i class="fa fa-bar-chart me-2"/>
                            Desglose detallado —
                            <field name="production_id" readonly="1" nolabel="1" class="oe_inline"/>
                        </h3>
                    </div>

                    <group col="3" class="mb-3">
                        <div>
                            <strong>Total presupuestado</strong><br/>
                            <field name="total_presupuestado" widget="monetary" nolabel="1" class="fs-4"/>
                        </div>
                        <div>
                            <strong>Total real</strong><br/>
                            <field name="total_actual" widget="monetary" nolabel="1" class="fs-4 text-primary"/>
                        </div>
                        <div>
                            <strong>Restante estimado</strong><br/>
                            <field name="total_restante" widget="monetary" nolabel="1" class="fs-4"/>
                        </div>
                    </group>

                    <h4 class="mt-3"><i class="fa fa-cubes me-1"/> Componentes (materia prima)</h4>
                    <p class="text-muted small mb-1">
                        Una fila por componente. Consumido = lo que ya ha pasado por la OF. Proveedor / PO te dice la compra concreta que trajo el material.
                    </p>
                    <field name="material_line_ids" nolabel="1" readonly="1"
                           context="{'tree_view_ref': 'apunts_costes_of.view_apunts_material_line_tree_simple'}"/>

                    <h4 class="mt-4"><i class="fa fa-cogs me-1"/> Operaciones / centros de trabajo</h4>
                    <p class="text-muted small mb-1">
                        Una fila por orden de trabajo (OT). Coste real = horas imputadas x tarifa empleado + tarifa centro. Si una OT desborda en horas reales vs planificadas, aquí lo ves directo.
                    </p>
                    <field name="labor_line_ids" nolabel="1" readonly="1"
                           context="{'tree_view_ref': 'apunts_costes_of.view_apunts_labor_line_tree_simple'}"/>

                </sheet>
                <footer>
                    <button string="Cerrar" class="btn-primary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
