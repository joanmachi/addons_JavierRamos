<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="sale_order_report_document_custom" inherit_id="sale.report_saleorder_document">
        <xpath expr="//table/thead/tr[1]/th[2]" position="after">
            <th class="text-right">Cajas</th>
        </xpath>
        <xpath expr="//table//tbody//tr[1]//td[2]" position="after">
            <td class="text-right">
                <span t-field="line.cantidad_caja" />
            </td>
        </xpath>
        
        
        <xpath expr="//table/thead/tr[1]/th[2]" position="after" >
            <th class="text-left" >Cantidad en caja</th>
        </xpath>
        <xpath expr="//table//tbody//tr[1]//td[2]" position="after" >
            <td class="text-left" >
                <span  t-field="line.cantidad_en_caja"   />
            </td>
        </xpath>
        

    </template>
</odoo>
