<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_account_invoice_custom" inherit_id="account.report_invoice_document">
        <xpath expr="//table[@name='invoice_line_table']//thead//tr[1]//th[@name='th_quantity']" position="after">
            <th class="text-right">Cajas</th>
        </xpath>
        <xpath expr="//table[@name='invoice_line_table']//tbody//tr[1]//td[2]" position="after">
            <td class="text-right">
                <span t-field="line.cantidad_caja" />
            </td>
        </xpath>

        <xpath expr="//table[@name='invoice_line_table']//thead//tr[1]//th[@name='th_quantity']" position="after">
            <th class="text-right" >Cantidad en cajas</th>
        </xpath>
        <xpath expr="//table[@name='invoice_line_table']//tbody//tr[1]//td[1]" position="after">
            <td class="text-right" >
                <span t-field="line.cantidad_en_caja" />
            </td>
        </xpath>

        
    </template>
</odoo>