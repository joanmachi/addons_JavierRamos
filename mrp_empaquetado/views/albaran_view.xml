<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="sh_stock_picking_form_view_custom" model="ir.ui.view">
        <field name="name">sh.stock.picking.form.view.custom</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form" />
        <field name="arch" type="xml">
          

            <xpath expr="//field[@name='move_ids_without_package']/list/field[@name='product_uom']" position="after">
                <field name="cantidad_en_caja"  />
                <field name="cantidad_caja" />
            </xpath>
         
        </field>
    </record>
</odoo>