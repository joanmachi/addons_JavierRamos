<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="stock_scrap_form_view_custom" model="ir.ui.view">
        <field name="name">stock_scrap_form_view.custom</field>
        <field name="model">stock.scrap</field>
        <field name="inherit_id" ref="stock.stock_scrap_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lot_id']" position="before">
                <field name="cantidad_caja" />
                <field name="cantidad_en_caja" />
            </xpath>
        
        </field>
    </record>
</odoo>