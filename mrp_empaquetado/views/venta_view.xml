<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="ale_order_form_view_custom" model="ir.ui.view">
        <field name="name">sale.order.form.view.custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
         

            <xpath expr="//field[@name='order_line']/list/field[@name='name']" position="after" >
                <field name="cantidad_en_caja" />
                <field name="cantidad_caja" />
            </xpath>
        </field>
    </record>
</odoo>
