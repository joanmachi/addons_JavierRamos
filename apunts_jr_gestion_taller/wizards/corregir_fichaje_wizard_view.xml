<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="apunts_corregir_fichaje_wizard_form" model="ir.ui.view">
        <field name="name">apunts.corregir.fichaje.wizard.form</field>
        <field name="model">apunts.corregir.fichaje.wizard</field>
        <field name="arch" type="xml">
            <form string="Desbloquear operario">
                <sheet>

                    <!-- Campos invisibles de soporte -->
                    <field name="tiene_fichaje_abierto" invisible="1"/>
                    <field name="productivity_abierta_id" invisible="1"/>
                    <field name="ofs_filtradas_ids" invisible="1"/>

                    <!-- Datos del bloqueo (siempre visible si existe) -->
                    <div class="alert alert-secondary" invisible="not motivo_bloqueo">
                        <i class="fa fa-lock me-1"/>
                        <strong>
                            <field name="motivo_bloqueo" readonly="1" nolabel="1"
                                   style="display:inline"/>
                        </strong>
                        — bloqueado el
                        <field name="fecha_bloqueo" readonly="1" nolabel="1"
                               style="display:inline" widget="datetime"/>
                    </div>

                    <!-- Operario (siempre) -->
                    <group>
                        <field name="employee_id" options="{'no_create': True}"/>
                        <field name="mostrar_todas_ofs"
                               help="Por defecto solo aparecen las OFs del operario. Marca para ver todas."/>
                    </group>

                    <!-- ═══════════════════════════════════════════════════════
                         CASO 1 — Fichado demasiado tiempo
                         Muestra: OF + OT del fichaje abierto, "fichado desde",
                         hora de salida a corregir.
                    ═══════════════════════════════════════════════════════ -->
                    <div invisible="not tiene_fichaje_abierto">
                        <div class="alert alert-warning">
                            <i class="fa fa-clock-o me-1"/>
                            <strong>Fichaje abierto detectado.</strong>
                            El operario lleva demasiado tiempo fichado.
                            Selecciona la OF y la fase, comprueba desde cuándo lleva
                            fichado y corrige la hora de salida.
                        </div>
                        <group string="Fichaje a cerrar">
                            <field name="production_id" string="Orden de Fabricación (OF)"
                                   options="{'no_create': True}"/>
                            <field name="workorder_id_abierto" string="Fase (OT)"
                                   options="{'no_create': True}"
                                   invisible="not production_id"/>
                            <field name="date_start_abierto" string="Fichado desde"
                                   readonly="1"
                                   invisible="not workorder_id_abierto"
                                   widget="datetime"/>
                            <field name="salida_real" string="Corregir salida a"
                                   invisible="not workorder_id_abierto"/>
                            <field name="motivo"
                                   invisible="not workorder_id_abierto"
                                   required="workorder_id_abierto"/>
                        </group>
                    </div>

                    <!-- ═══════════════════════════════════════════════════════
                         CASO 2 — Inactividad (sin fichaje activo)
                         Muestra: buscador OF, buscador OT dentro de esa OF,
                         rango de fechas del periodo a registrar.
                    ═══════════════════════════════════════════════════════ -->
                    <div invisible="tiene_fichaje_abierto">
                        <div class="alert alert-info">
                            <i class="fa fa-search me-1"/>
                            <strong>Operario sin fichaje activo.</strong>
                            Estaba en el sistema pero sin ninguna OF activa.
                            Busca la OF y la fase donde estuvo trabajando y
                            pon el rango horario para registrar ese periodo.
                        </div>
                        <group string="Periodo a registrar">
                            <field name="production_id" string="Orden de Fabricación (OF)"
                                   options="{'no_create': True}"/>
                            <field name="workorder_id_nuevo" string="Fase (OT)"
                                   options="{'no_create': True}"
                                   invisible="not production_id"/>
                            <field name="date_start_nuevo" string="Inicio del periodo"
                                   invisible="not production_id"/>
                            <field name="date_end_nuevo" string="Fin del periodo"
                                   invisible="not production_id"/>
                            <field name="motivo"
                                   invisible="not production_id"
                                   required="production_id"/>
                        </group>
                    </div>

                    <!-- ═══════════════════════════════════════════════════════
                         Tabla de fichajes editables (ambos casos)
                    ═══════════════════════════════════════════════════════ -->
                    <separator string="Todos los fichajes del operario (editables)"/>
                    <field name="fichajes_editables_ids" nolabel="1">
                        <list string="Fichajes" editable="bottom" create="0" delete="1">
                            <field name="apunts_production_id" string="OF" readonly="1"/>
                            <field name="workorder_id" string="OT" readonly="1"/>
                            <field name="workcenter_id" string="Centro" optional="hide" readonly="1"/>
                            <field name="date_start" string="Entrada"/>
                            <field name="date_end" string="Salida (vacío = abierto)"/>
                            <field name="duration" string="Duración (min)" readonly="1"
                                   widget="float_time"/>
                        </list>
                    </field>

                </sheet>
                <footer>
                    <button name="action_aplicar" type="object"
                            string="Aplicar y desbloquear" class="btn-primary"/>
                    <button special="cancel" string="Cancelar"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="apunts_corregir_fichaje_action" model="ir.actions.act_window">
        <field name="name">Corregir fichaje / desbloquear</field>
        <field name="res_model">apunts.corregir.fichaje.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
