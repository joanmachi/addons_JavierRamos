<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="apunts_corregir_fichaje_wizard_form" model="ir.ui.view">
        <field name="name">apunts.corregir.fichaje.wizard.form</field>
        <field name="model">apunts.corregir.fichaje.wizard</field>
        <field name="arch" type="xml">
            <form string="Desbloquear operario">
                <sheet>

                    <!-- Campos invisibles de soporte -->
                    <field name="tiene_fichaje_abierto" invisible="1"/>
                    <field name="productivity_abierta_id" invisible="1"/>
                    <field name="ofs_filtradas_ids" invisible="1"/>

                    <!-- Info del bloqueo -->
                    <group invisible="not motivo_bloqueo">
                        <field name="motivo_bloqueo" readonly="1" string="Motivo del bloqueo"/>
                        <field name="fecha_bloqueo" readonly="1" string="Bloqueado desde"/>
                    </group>

                    <!-- CASO 1: hay fichaje abierto (fichado demasiado tiempo) -->
                    <div invisible="not tiene_fichaje_abierto" class="alert alert-warning">
                        <i class="fa fa-clock-o me-1"/>
                        <strong>Fichaje abierto detectado.</strong>
                        El operario lleva demasiado tiempo fichado en una OF.
                        Corrige la hora de salida real y aplica para cerrar el fichaje y desbloquearle.
                    </div>

                    <!-- CASO 2: no hay fichaje abierto (inactividad) -->
                    <div invisible="tiene_fichaje_abierto" class="alert alert-info">
                        <i class="fa fa-search me-1"/>
                        <strong>Operario sin fichaje activo.</strong>
                        Estaba fichado en el sistema pero sin ninguna OF activa.
                        Selecciona la OF y la fase donde estuvo trabajando, pon el rango horario
                        y aplica para registrar ese periodo y desbloquearle.
                    </div>

                    <group>
                        <field name="employee_id" options="{'no_create': True}"/>
                    </group>

                    <!-- ── CASO 1: cerrar fichaje abierto ── -->
                    <group invisible="not tiene_fichaje_abierto" string="Corregir salida">
                        <field name="salida_real" string="Hora de salida real"/>
                        <field name="motivo" placeholder="Ej. olvidó cerrar fin de jornada"/>
                    </group>

                    <group invisible="not tiene_fichaje_abierto" string="OF del fichaje abierto">
                        <field name="mostrar_todas_ofs"/>
                        <field name="production_id" options="{'no_create': True}"/>
                    </group>

                    <div invisible="not (tiene_fichaje_abierto and production_id)">
                        <separator string="Fichajes del operario en esta OF"/>
                        <field name="fichajes_operario_of_html" nolabel="1"/>
                    </div>

                    <!-- ── CASO 2: crear nuevo fichaje por inactividad ── -->
                    <group invisible="tiene_fichaje_abierto" string="OF y periodo trabajado">
                        <field name="mostrar_todas_ofs"/>
                        <field name="production_id" options="{'no_create': True}"
                               string="Orden de Fabricación"/>
                        <field name="workorder_id_nuevo" options="{'no_create': True}"
                               invisible="not production_id"/>
                        <field name="date_start_nuevo" invisible="not production_id"/>
                        <field name="date_end_nuevo" invisible="not production_id"/>
                        <field name="motivo" placeholder="Ej. se distrajo entre fichajes"
                               invisible="not production_id"/>
                    </group>

                    <!-- Fichajes editables (visible en ambos casos) -->
                    <separator string="Todos los fichajes del operario (editables)"/>
                    <field name="fichajes_editables_ids" nolabel="1">
                        <list string="Fichajes del operario" editable="bottom" create="0" delete="1">
                            <field name="apunts_production_id" string="OF" readonly="1"/>
                            <field name="workorder_id" string="OT" readonly="1"/>
                            <field name="workcenter_id" string="Centro" optional="hide" readonly="1"/>
                            <field name="date_start" string="Entrada"/>
                            <field name="date_end" string="Salida (vacío=abierto)"/>
                            <field name="duration" string="Duración (min)" readonly="1" widget="float_time"/>
                        </list>
                    </field>

                    <separator string="Otros fichajes abiertos ahora mismo (todos los operarios)"/>
                    <field name="productividades_abiertas_html" nolabel="1"/>

                </sheet>
                <footer>
                    <button name="action_aplicar" type="object"
                            string="Aplicar y desbloquear" class="btn-primary"/>
                    <button special="cancel" string="Cancelar"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="apunts_corregir_fichaje_action" model="ir.actions.act_window">
        <field name="name">Corregir fichaje / desbloquear</field>
        <field name="res_model">apunts.corregir.fichaje.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
