<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="apunts_employee_list_resumen" model="ir.ui.view">
        <field name="name">apunts.employee.list.resumen</field>
        <field name="model">hr.employee</field>
        <field name="arch" type="xml">
            <list string="Operarios" create="0" delete="0" edit="1" multi_edit="1"
                  decoration-success="apunts_productivity_actual_id"
                  decoration-danger="apunts_taller_bloqueado">
                <field name="name" readonly="1"/>
                <field name="department_id" optional="hide" readonly="1"/>
                <field name="pin" string="PIN" optional="hide"/>
                <field name="apunts_productivity_actual_id" column_invisible="1"/>
                <field name="apunts_of_actual_id" column_invisible="1"/>
                <field name="apunts_ot_actual_id" column_invisible="1"/>
                <field name="apunts_ofs_actuales_summary" string="OFs actuales"/>
                <field name="apunts_centro_actual_id" string="Centro" optional="hide"/>
                <field name="apunts_fichado_desde" string="Fichado desde"/>
                <field name="apunts_llevan_h" string="Llevan (h)" widget="float_time" readonly="1"/>
                <field name="apunts_horas_hoy" string="Horas HOY" widget="float_time" readonly="1"/>
                <field name="apunts_horas_semana" string="Horas semana" widget="float_time" readonly="1" optional="show"/>
                <field name="apunts_fichaje_activo_count" string="N° fichajes abiertos" readonly="1" optional="hide"/>
                <field name="apunts_taller_bloqueado" string="Bloqueado" widget="boolean_toggle"/>
                <field name="apunts_taller_motivo_bloqueo" string="Motivo bloqueo" optional="show"/>
                <field name="apunts_taller_fecha_bloqueo" string="Bloqueado el" optional="hide" readonly="1"/>
                <button name="action_apunts_ver_of_actual" type="object"
                        string="Ver OF" icon="fa-external-link"
                        class="btn btn-sm btn-link"
                        invisible="not apunts_of_actual_id"/>
                <button name="action_apunts_desbloquear_taller" type="object"
                        string="Desbloquear" icon="fa-unlock"
                        class="btn btn-sm btn-success"
                        invisible="not apunts_taller_bloqueado"/>
            </list>
        </field>
    </record>

    <record id="apunts_employee_search" model="ir.ui.view">
        <field name="name">apunts.employee.search</field>
        <field name="model">hr.employee</field>
        <field name="arch" type="xml">
            <search string="Operarios">
                <field name="name"/>
                <field name="department_id"/>
                <field name="pin"/>
                <filter name="filter_bloqueados" string="Bloqueados"
                        domain="[('apunts_taller_bloqueado','=',True)]"/>
                <filter name="filter_no_bloqueados" string="No bloqueados"
                        domain="[('apunts_taller_bloqueado','=',False)]"/>
                <group string="Agrupar por">
                    <filter name="group_bloqueado" string="Bloqueado/No bloqueado"
                            context="{'group_by':'apunts_taller_bloqueado'}"/>
                    <filter name="group_dept" string="Departamento"
                            context="{'group_by':'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="apunts_action_empleados_resumen" model="ir.actions.act_window">
        <field name="name">Operarios (resumen horas)</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="apunts_employee_list_resumen"/>
        <field name="search_view_id" ref="apunts_employee_search"/>
        <field name="context">{'search_default_group_bloqueado': 1}</field>
    </record>

    <record id="apunts_action_fichajes_empleado" model="ir.actions.act_window">
        <field name="name">Fichajes del empleado</field>
        <field name="res_model">mrp.workcenter.productivity</field>
        <field name="view_mode">list,pivot</field>
        <field name="domain">[('employee_id', '=', active_id)]</field>
        <field name="search_view_id" ref="apunts_productivity_search"/>
    </record>


</odoo>
