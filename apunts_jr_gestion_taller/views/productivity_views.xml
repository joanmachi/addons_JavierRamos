<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="apunts_productivity_list_activos" model="ir.ui.view">
        <field name="name">apunts.productivity.list.activos</field>
        <field name="model">mrp.workcenter.productivity</field>
        <field name="arch" type="xml">
            <list string="Operarios fichados ahora" create="0" delete="0" edit="1"
                  decoration-danger="apunts_emp_bloqueado"
                  decoration-success="not apunts_emp_bloqueado">
                <field name="apunts_emp_bloqueado" column_invisible="1"/>
                <field name="employee_id" string="Operario" readonly="1"/>
                <field name="apunts_production_id" string="OF" readonly="1"/>
                <field name="workorder_id" string="OT (fase)" readonly="1"/>
                <field name="workcenter_id" string="Centro" optional="hide" readonly="1"/>
                <field name="date_start" string="Fichado desde"/>
                <field name="apunts_duracion_viva" string="Llevan (h)" widget="float_time" readonly="1"/>
                <field name="apunts_emp_horas_hoy" string="Horas HOY" widget="float_time" readonly="1"/>
                <field name="apunts_emp_horas_semana" string="Horas semana" widget="float_time" readonly="1" optional="show"/>
                <field name="apunts_emp_motivo_bloqueo" string="Motivo bloqueo" optional="show" readonly="1"/>
                <button name="action_apunts_ver_of" type="object"
                        string="Ver OF" icon="fa-external-link"
                        class="btn btn-sm btn-primary"
                        invisible="not apunts_production_id"/>
                <button name="action_apunts_cerrar_ahora" type="object"
                        string="Cerrar fichaje" icon="fa-stop-circle"
                        class="btn btn-sm btn-warning"
                        invisible="date_end"
                        confirm="Cerrar este fichaje con la hora actual."/>
                <button name="action_apunts_desbloquear_emp" type="object"
                        string="Desbloquear" icon="fa-unlock"
                        class="btn btn-sm btn-success"
                        invisible="not apunts_emp_bloqueado"/>
            </list>
        </field>
    </record>

    <record id="apunts_productivity_search" model="ir.ui.view">
        <field name="name">apunts.productivity.search</field>
        <field name="model">mrp.workcenter.productivity</field>
        <field name="arch" type="xml">
            <search string="Fichajes">
                <field name="employee_id"/>
                <field name="workorder_id"/>
                <field name="apunts_production_id" string="OF"/>
                <field name="workcenter_id"/>
                <filter name="filter_abiertos" string="Solo abiertos"
                        domain="[('date_end', '=', False)]"/>
                <filter name="filter_hoy" string="Hoy"
                        domain="[('date_start', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter name="filter_semana" string="Últimos 7 días"
                        domain="[('date_start', '&gt;=', (context_today() - relativedelta(days=7)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <group string="Agrupar por">
                    <filter name="group_employee" string="Operario" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_of" string="OF" context="{'group_by': 'apunts_production_id'}"/>
                    <filter name="group_dia" string="Día" context="{'group_by': 'date_start:day'}"/>
                    <filter name="group_semana" string="Semana" context="{'group_by': 'date_start:week'}"/>
                    <filter name="group_mes" string="Mes" context="{'group_by': 'date_start:month'}"/>
                    <filter name="group_centro" string="Centro" context="{'group_by': 'workcenter_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="apunts_productivity_pivot" model="ir.ui.view">
        <field name="name">apunts.productivity.pivot</field>
        <field name="model">mrp.workcenter.productivity</field>
        <field name="arch" type="xml">
            <pivot string="Horas por operario" sample="0">
                <field name="employee_id" type="row"/>
                <field name="apunts_production_id" type="row"/>
                <field name="date_start" type="col" interval="day"/>
                <field name="duration" type="measure" string="Minutos fichados"/>
            </pivot>
        </field>
    </record>

    <record id="apunts_action_fichados_ahora" model="ir.actions.act_window">
        <field name="name">Operarios fichados ahora</field>
        <field name="res_model">mrp.workcenter.productivity</field>
        <field name="view_mode">list</field>
        <field name="domain">[('date_end', '=', False), ('employee_id', '!=', False)]</field>
        <field name="context">{'search_default_group_employee': 1}</field>
        <field name="search_view_id" ref="apunts_productivity_search"/>
        <field name="view_id" ref="apunts_productivity_list_activos"/>
    </record>

    <record id="apunts_action_horas_pivot" model="ir.actions.act_window">
        <field name="name">Histórico fichajes</field>
        <field name="res_model">mrp.workcenter.productivity</field>
        <field name="view_mode">list,pivot</field>
        <field name="domain">[('employee_id', '!=', False)]</field>
        <field name="search_view_id" ref="apunts_productivity_search"/>
        <field name="context">{'search_default_filter_semana': 1}</field>
    </record>

</odoo>
