<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="apunts_cron_carga_snapshot" model="ir.cron">
        <field name="name">Apunts: foto diaria de carga por centro</field>
        <field name="model_id" ref="model_apunts_carga_snapshot"/>
        <field name="state">code</field>
        <field name="code">model.cron_tomar_foto()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 04:30:00')"/>
        <field name="active" eval="True"/>
    </record>
</odoo>
