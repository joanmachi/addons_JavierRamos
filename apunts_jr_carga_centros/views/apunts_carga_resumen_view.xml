<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="apunts_carga_resumen_form" model="ir.ui.view">
        <field name="name">apunts.carga.centros.resumen.form</field>
        <field name="model">apunts.carga.centros.resumen</field>
        <field name="arch" type="xml">
            <form string="Resumen carga centros" create="0" delete="0">
                <sheet>
                    <!-- SELECTOR DE MODO + FILTRO FECHAS (mismo patrón que Resumen WIP) -->
                    <div class="d-flex flex-wrap align-items-center gap-3 mb-3 p-3 bg-light rounded">
                        <div class="d-flex align-items-center gap-2">
                            <span class="fw-semibold text-muted">Vista:</span>
                            <field name="modo" widget="radio" nolabel="1"/>
                        </div>
                        <div class="d-flex align-items-center gap-2" invisible="modo != 'historico'">
                            <span class="fw-semibold text-muted">Fichajes entre</span>
                            <field name="fecha_desde" nolabel="1" placeholder="Desde..."/>
                            <span class="text-muted">–</span>
                            <field name="fecha_hasta" nolabel="1" placeholder="Hasta..."/>
                        </div>
                    </div>

                    <div class="oe_title mb-3">
                        <h1 invisible="modo != 'en_curso'">Resumen Carga Centros de Trabajo</h1>
                        <h1 invisible="modo != 'historico'">Histórico Carga Centros</h1>
                        <p class="text-muted" invisible="modo != 'en_curso'">
                            Foto actual de la carga de cada centro de trabajo:
                            qué hay pendiente, qué se ha fichado los últimos 7 días
                            y el acumulado histórico total.
                        </p>
                        <p class="text-muted" invisible="modo != 'historico'">
                            Horas fichadas en los centros dentro del periodo elegido
                            (por fecha de cierre del fichaje). Sin fechas: todo el histórico.
                        </p>
                    </div>

                    <div class="d-flex justify-content-center gap-2 mb-4">
                        <button name="action_open_lista_centros" type="object"
                                string="Ver lista de centros"
                                class="btn btn-lg btn-primary"
                                invisible="modo != 'en_curso'"/>
                        <button name="action_open_historico_centros" type="object"
                                string="HISTÓRICO — desglose por centro"
                                class="btn btn-lg btn-info"
                                invisible="modo != 'historico'"/>
                    </div>

                    <!-- TARJETAS HISTÓRICO -->
                    <div class="row g-3" invisible="modo != 'historico'">
                        <div class="col-md-3 col-sm-6">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Centros que trabajaron</div>
                                    <div class="display-5 fw-bold text-primary">
                                        <field name="hist_n_centros" nolabel="1" readonly="1"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Centros con al menos un fichaje cerrado en el periodo.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Horas fichadas (periodo)</div>
                                    <div class="display-6 fw-bold text-success">
                                        <field name="hist_horas" nolabel="1" readonly="1" widget="float_time"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Suma de horas fichadas por operarios en todos los
                                        centros dentro del periodo.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Días equivalentes</div>
                                    <div class="display-6 fw-bold text-success">
                                        <field name="hist_dias" nolabel="1" readonly="1" widget="float" digits="[16,1]"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Días laborales (8 h/día) equivalentes a las horas del periodo.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Fichajes cerrados</div>
                                    <div class="display-5 fw-bold text-secondary">
                                        <field name="hist_n_fichajes" nolabel="1" readonly="1"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Nº de fichajes de operario cerrados en el periodo.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6" invisible="not fecha_desde or not fecha_hasta">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Horas/día de media</div>
                                    <div class="display-6 fw-bold text-info">
                                        <field name="hist_horas_media_dia" nolabel="1" readonly="1" widget="float" digits="[16,1]"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Horas del periodo entre los días naturales del rango elegido.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- TARJETAS EN CURSO -->
                    <div class="row g-3" invisible="modo != 'en_curso'">
                        <div class="col-md-3 col-sm-6">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Centros activos</div>
                                    <div class="display-5 fw-bold text-primary">
                                        <field name="n_centros" nolabel="1" readonly="1"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Centros de trabajo dados de alta y activos.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Con trabajo pendiente</div>
                                    <div class="display-5 fw-bold text-warning">
                                        <field name="n_centros_activos" nolabel="1" readonly="1"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Centros que tienen al menos una orden de trabajo
                                        en estado ready / pending / progress.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Horas pendientes (total)</div>
                                    <div class="display-6 fw-bold text-danger">
                                        <field name="total_horas_pendientes" nolabel="1" readonly="1" widget="float_time"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Suma de minutos previstos de TODAS las órdenes de trabajo
                                        abiertas, en horas (HH:MM).
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Días de trabajo pendientes</div>
                                    <div class="display-6 fw-bold text-danger">
                                        <field name="total_dias_pendientes" nolabel="1" readonly="1" widget="float" digits="[16,1]"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Días laborales (8 h/día) equivalentes al total de horas pendientes.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Horas reales (7 días)</div>
                                    <div class="display-6 fw-bold text-success">
                                        <field name="total_horas_reales_semana" nolabel="1" readonly="1" widget="float_time"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Suma de minutos fichados por operarios en TODOS
                                        los centros durante los últimos 7 días.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Horas reales (15 días)</div>
                                    <div class="display-6 fw-bold text-success">
                                        <field name="total_horas_reales_15d" nolabel="1" readonly="1" widget="float_time"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Suma de minutos fichados por operarios en TODOS
                                        los centros durante los últimos 15 días.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Días reales (15 días)</div>
                                    <div class="display-6 fw-bold text-success">
                                        <field name="total_dias_reales_15d" nolabel="1" readonly="1" widget="float" digits="[16,1]"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Días laborales (8 h/día) equivalentes a las horas
                                        fichadas en todos los centros en los últimos 15 días.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Horas reales (30 días)</div>
                                    <div class="display-6 fw-bold text-success">
                                        <field name="total_horas_reales_30d" nolabel="1" readonly="1" widget="float_time"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Suma de minutos fichados por operarios en TODOS
                                        los centros durante los últimos 30 días.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Días reales (30 días)</div>
                                    <div class="display-6 fw-bold text-success">
                                        <field name="total_dias_reales_30d" nolabel="1" readonly="1" widget="float" digits="[16,1]"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Días laborales (8 h/día) equivalentes a las horas
                                        fichadas en todos los centros en los últimos 30 días.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Horas fichadas (histórico total)</div>
                                    <div class="display-6 fw-bold text-secondary">
                                        <field name="total_horas_reales_total" nolabel="1" readonly="1" widget="float_time"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Total acumulado de horas fichadas en todos los centros
                                        desde el inicio, sin filtro de fechas.
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6">
                            <div class="card shadow-sm h-100">
                                <div class="card-body text-center py-3">
                                    <div class="text-uppercase fw-semibold small text-muted mb-1">Días fichados (histórico total)</div>
                                    <div class="display-6 fw-bold text-secondary">
                                        <field name="total_dias_reales_total" nolabel="1" readonly="1" widget="float" digits="[16,1]"/>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        Días laborales (8 h/día) equivalentes al total
                                        histórico de horas fichadas en todos los centros.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <field name="total_workorders_pendientes" invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Desglose del histórico: fichajes por centro (pivote + lista) -->
    <record id="apunts_carga_hist_pivot" model="ir.ui.view">
        <field name="name">apunts.carga.hist.productivity.pivot</field>
        <field name="model">mrp.workcenter.productivity</field>
        <field name="arch" type="xml">
            <pivot string="Histórico por centro" sample="1">
                <field name="workcenter_id" type="row"/>
                <field name="date_end" interval="month" type="col"/>
                <field name="duration" type="measure" string="Minutos fichados"/>
            </pivot>
        </field>
    </record>

    <record id="apunts_carga_hist_list" model="ir.ui.view">
        <field name="name">apunts.carga.hist.productivity.list</field>
        <field name="model">mrp.workcenter.productivity</field>
        <field name="arch" type="xml">
            <list string="Histórico por centro" create="false" edit="false" delete="false">
                <field name="date_end" string="Cerrado el"/>
                <field name="workcenter_id"/>
                <field name="employee_id" optional="show"/>
                <field name="workorder_id" optional="show"/>
                <field name="duration" sum="Total" string="Minutos" digits="[16,1]"/>
            </list>
        </field>
    </record>

    <record id="apunts_action_carga_resumen_srv" model="ir.actions.server">
        <field name="name">Resumen carga centros</field>
        <field name="model_id" ref="model_apunts_carga_centros_resumen"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_resumen()</field>
    </record>

</odoo>
