<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="apunts_view_mrp_workcenter_carga_list" model="ir.ui.view">
        <field name="name">mrp.workcenter.carga.list</field>
        <field name="model">mrp.workcenter</field>
        <field name="arch" type="xml">
            <list string="Carga centros de trabajo" create="0" delete="0" edit="0"
                  decoration-warning="apunts_dias_pendientes &gt; 15 and apunts_dias_pendientes &lt;= 30"
                  decoration-danger="apunts_dias_pendientes &gt; 30">
                <field name="name" string="Centro"/>
                <field name="apunts_n_workorders_pendientes"
                       string="Órdenes de trabajo abiertas"
                       sum="Total órdenes de trabajo"/>
                <field name="apunts_horas_pendientes"
                       string="Horas pendientes"
                       sum="Total horas pendientes"
                       widget="float_time"/>
                <field name="apunts_dias_pendientes"
                       string="Días pendientes"
                       sum="Total días pendientes"
                       widget="float"
                       digits="[16,1]"/>
                <field name="apunts_horas_reales_semana"
                       string="Horas reales (7 días)"
                       sum="Total horas reales"
                       widget="float_time"/>
                <field name="apunts_dias_reales_semana"
                       string="Días reales (7 días)"
                       sum="Total días reales"
                       widget="float"
                       digits="[16,1]"
                       optional="hide"/>
                <field name="apunts_horas_reales_15d"
                       string="Horas reales (15 días)"
                       sum="Total horas reales 15d"
                       widget="float_time"
                       optional="hide"/>
                <field name="apunts_dias_reales_15d"
                       string="Días reales (15 días)"
                       sum="Total días reales 15d"
                       widget="float"
                       digits="[16,1]"
                       optional="hide"/>
                <field name="apunts_horas_reales_30d"
                       string="Horas reales (30 días)"
                       sum="Total horas reales 30d"
                       widget="float_time"
                       optional="hide"/>
                <field name="apunts_dias_reales_30d"
                       string="Días reales (30 días)"
                       sum="Total días reales 30d"
                       widget="float"
                       digits="[16,1]"
                       optional="hide"/>
                <field name="apunts_horas_reales_total"
                       string="Horas fichadas (histórico)"
                       sum="Total horas históricas"
                       widget="float_time"
                       optional="hide"/>
                <field name="apunts_dias_reales_total"
                       string="Días fichados (histórico)"
                       sum="Total días históricos"
                       widget="float"
                       digits="[16,1]"
                       optional="hide"/>
                <field name="apunts_carga_pct"
                       string="% carga (30 días)"
                       widget="float"
                       digits="[16,1]"
                       optional="hide"/>
                <field name="apunts_carga_pct_real"
                       string="% carga s/ ritmo real"
                       widget="float"
                       digits="[16,1]"
                       optional="show"/>
                <field name="costs_hour" string="Coste/h máquina" optional="hide"/>
                <field name="employee_costs_hour" string="Coste/h operario" optional="hide"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="apunts_view_mrp_workcenter_carga_search" model="ir.ui.view">
        <field name="name">mrp.workcenter.carga.search</field>
        <field name="model">mrp.workcenter</field>
        <field name="arch" type="xml">
            <search string="Buscar centro">
                <field name="name" string="Centro"/>
            </search>
        </field>
    </record>

    <record id="apunts_action_carga_centros_list" model="ir.actions.act_window">
        <field name="name">Carga por centro</field>
        <field name="res_model">mrp.workcenter</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="apunts_view_mrp_workcenter_carga_list"/>
        <field name="search_view_id" ref="apunts_view_mrp_workcenter_carga_search"/>
        <field name="domain">[('active','=',True)]</field>
    </record>

</odoo>
