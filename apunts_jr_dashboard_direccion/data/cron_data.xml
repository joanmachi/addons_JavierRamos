<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="apunts_cron_direccion_snapshot" model="ir.cron">
        <field name="name">Apunts: foto semanal KPIs dirección</field>
        <field name="model_id" ref="model_apunts_direccion_snapshot"/>
        <field name="state">code</field>
        <field name="code">model.cron_tomar_foto()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">weeks</field>
        <field name="nextcall" eval="(DateTime.now() + timedelta(days=((7 - DateTime.now().weekday()) or 7))).strftime('%Y-%m-%d 05:00:00')"/>
        <field name="active" eval="True"/>
    </record>
</odoo>
