<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Heredar de la vista BASE de account_batch_payment (no de la SEPA inherit)
         para garantizar que la columna salga siempre, independientemente de que
         account_sepa_direct_debit esté en versión X u otra. -->
    <record id="apunts_view_account_batch_payment_form_fecha_cobro" model="ir.ui.view">
        <field name="name">apunts.account.batch.payment.form.fecha.cobro</field>
        <field name="model">account.batch.payment</field>
        <field name="inherit_id" ref="account_batch_payment.view_batch_payment_form"/>
        <field name="arch" type="xml">
            <!-- Hacer la lista editable inline -->
            <xpath expr="//field[@name='payment_ids']/list" position="attributes">
                <attribute name="editable">bottom</attribute>
            </xpath>
            <!-- Añadir columna Fecha cobro SIEMPRE visible (sin optional) -->
            <xpath expr="//field[@name='payment_ids']/list//field[@name='date']" position="after">
                <field name="apunts_sdd_collection_date" string="Fecha cobro" widget="date"/>
            </xpath>
        </field>
    </record>

</odoo>
