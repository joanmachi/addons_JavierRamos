<odoo>
    <record id="sale_order_form_view_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.view.custom.extra</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">

            <xpath expr="//sheet/notebook/page[1]/field[@name='order_line']/list/field[@name='name']" position="after">
              <field name="cliente_referencia" required="1"/>
            </xpath>
            <xpath expr="//sheet/notebook/page[1]/field[@name='order_line']/list/field[@name='name']" position="after">
              <field name="cliente_pedido" required="1"/>
            </xpath>
        </field>
    </record>
    <record id="account_move_form_view_inherit" model="ir.ui.view">
        <field name="name">account.move.form.view.custom.extra</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">

            <xpath expr="//page[@id='invoice_tab']/field[@name='invoice_line_ids']/list/field[@name='name']" position="after">
              <field name="cliente_referencia"/>
            </xpath>
            <xpath expr="//page[@id='aml_tab']/field[@name='line_ids']/list/field[@name='name']" position="after">
              <field name="cliente_referencia"/><field name="cliente_referencia" invisible="1"/>
            </xpath>
            <xpath expr="//page[@id='invoice_tab']/field[@name='invoice_line_ids']/list/field[@name='name']" position="after">
              <field name="cliente_pedido"/>
            </xpath>
            <xpath expr="//page[@id='aml_tab']/field[@name='line_ids']/list/field[@name='name']" position="after">
              <field name="cliente_pedido"/><field name="cliente_pedido" invisible="1"/>
            </xpath>
        </field>
    </record>

</odoo>