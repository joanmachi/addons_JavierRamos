<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_move_form_apunts_secondary_uom_pack" model="ir.ui.view">
        <field name="name">account.move.form.apunts.secondary.uom.pack</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='product_uom_id'][1]" position="before">
                <field name="apunts_display_uom_name"
                       string="UdM"
                       optional="show"
                       width="92px"
                       readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='product_uom_id'][1]" position="attributes">
                <attribute name="optional">hide</attribute>
                <attribute name="string">UdM nativa</attribute>
            </xpath>
        </field>
    </record>

</odoo>
